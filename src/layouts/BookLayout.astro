---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  author: string;
  tag: string;
  slug: string;
  hasTakeaways: boolean;
  hasDeepDive: boolean;
  metaDescription?: string;
}

const { title, author, tag, slug, hasTakeaways, hasDeepDive, metaDescription } = Astro.props;
---

<BaseLayout title={`${title} — Bookshelf`} description={metaDescription}>
  <a class="overlay-back" href="/">&#8592; Back to Bookshelf</a>
  <a class="overlay-close" href="/" aria-label="Close">&times;</a>

  <div class="overlay-content">
    <span class="overlay-tag">{tag}</span>
    <h1 class="overlay-book-title">{title}</h1>
    <p class="overlay-book-author">By {author}</p>

    {hasTakeaways && (
      <a class="overlay-takeaways-btn" href={`/books/${slug}/takeaways/`}>
        My Personal Takeaways &rarr;
      </a>
    )}

    <slot />

    {hasDeepDive && (
      <a class="go-deeper-btn" href={`/books/${slug}/deep-dive/`}>
        Go Deeper &rarr;
      </a>
    )}
  </div>
</BaseLayout>
