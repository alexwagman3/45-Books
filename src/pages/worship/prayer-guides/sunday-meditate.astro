---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Worship — Sunday: Meditate"
  description="A Sunday devotional for worship and Sabbath rest, with morning preparation, post-worship reflection, and afternoon Sabbath rhythms."
>
  <div class="takeaways-content pg-page">
    <a href="/worship/takeaways-weekly-prayer-plan/" class="pg-back">← Back to Weekly Prayer Plan</a>

    <div class="pg-header">
      <div class="pg-day-badge">Sunday · Meditate</div>
      <h1 class="pg-title">Sunday Devotional</h1>
      <p class="pg-subtitle">A Day of Worship &amp; Sabbath Rest</p>
      <p class="pg-intro">Embrace a day of intentional worship and restorative rest. Seek the Lord's presence at church as you sing, take communion, and listen to the reading of the word. Then commit to observing the Sabbath by replacing digital habits with life-giving activities such as reading, journaling, spending time in nature, or engaging in meaningful conversations. Practice saying "no" to productivity and "yes" to savoring God's presence and creation.</p>
    </div>

    <!-- MORNING -->
    <div class="pg-time-block">
      <div class="pg-time-label">
        <span class="pg-time-icon">☀</span>
        <span>Morning</span>
      </div>
      <h2 class="pg-time-title">Prepare to Worship</h2>
    </div>

    <section class="pg-section">
      <p class="pg-section-intro">Before heading to church, take a few minutes to quiet your heart.</p>
      <div class="pg-question-list">
        <div class="pg-question">
          <p>What am I bringing into worship today — joy, heaviness, gratitude, anxiety, expectation?</p>
          <div class="pg-write-line"></div>
          <div class="pg-write-line"></div>
        </div>
        <div class="pg-question">
          <p>Is there any unconfessed sin or relational tension I need to surrender before entering God's presence?</p>
          <div class="pg-write-line"></div>
          <div class="pg-write-line"></div>
        </div>
        <div class="pg-question pg-question--prayer">
          <p class="pg-prayer-prompt">Lord, open my eyes to see You, my ears to hear You, and my heart to receive from You today.</p>
        </div>
      </div>
    </section>

    <!-- AFTER WORSHIP -->
    <div class="pg-time-block">
      <div class="pg-time-label">
        <span class="pg-time-icon">✦</span>
        <span>After Worship</span>
      </div>
      <h2 class="pg-time-title">Reflect</h2>
    </div>

    <section class="pg-section pg-section--alt">
      <div class="pg-question-list">
        <div class="pg-question">
          <p>What song lyric stood out to me today? Why?</p>
          <div class="pg-write-line"></div>
          <div class="pg-write-line"></div>
        </div>
        <div class="pg-question">
          <p>What Scripture verse or phrase from the sermon captured my attention?</p>
          <div class="pg-write-line"></div>
          <div class="pg-write-line"></div>
        </div>
        <div class="pg-question">
          <p>What is one thing God spoke to my heart during the service?</p>
          <div class="pg-write-line"></div>
          <div class="pg-write-line"></div>
        </div>
      </div>
    </section>

    <!-- AFTERNOON -->
    <div class="pg-time-block">
      <div class="pg-time-label">
        <span class="pg-time-icon">◑</span>
        <span>Afternoon</span>
      </div>
      <h2 class="pg-time-title">Embrace Sabbath</h2>
    </div>

    <section class="pg-section">
      <div class="pg-question-list">
        <div class="pg-question">
          <p>Which unfinished tasks or distractions is the Holy Spirit inviting me to rest from today?</p>
          <div class="pg-write-line"></div>
          <div class="pg-write-line"></div>
        </div>
        <div class="pg-question">
          <p>What does "restorative rest" look like for my soul, mind, and body right now?</p>
          <div class="pg-write-line"></div>
          <div class="pg-write-line"></div>
        </div>
        <div class="pg-question">
          <p>Where in nature can I savor God's presence and creation today?</p>
          <div class="pg-write-line"></div>
          <div class="pg-write-line"></div>
        </div>
      </div>
    </section>

    <!-- SABBATH RHYTHMS -->
    <div class="pg-scripture-header">
      <h2 class="pg-scripture-title">Sabbath Rhythms to Consider</h2>
    </div>

    <section class="pg-section pg-section--alt">
      <div class="pg-rhythm-grid">
        <div class="pg-rhythm-item">
          <span class="pg-rhythm-check"></span>
          <span>Take a walk outside without your phone</span>
        </div>
        <div class="pg-rhythm-item">
          <span class="pg-rhythm-check"></span>
          <span>Read a book that feeds your soul</span>
        </div>
        <div class="pg-rhythm-item">
          <span class="pg-rhythm-check"></span>
          <span>Have an unhurried conversation with someone</span>
        </div>
        <div class="pg-rhythm-item">
          <span class="pg-rhythm-check"></span>
          <span>Sit in silence for 10–15 minutes</span>
        </div>
        <div class="pg-rhythm-item">
          <span class="pg-rhythm-check"></span>
          <span>Journal about what God is doing in your life</span>
        </div>
        <div class="pg-rhythm-item">
          <span class="pg-rhythm-check"></span>
          <span>Nap without guilt</span>
        </div>
        <div class="pg-rhythm-item">
          <span class="pg-rhythm-check"></span>
          <span>Share a slow meal with family or friends</span>
        </div>
        <div class="pg-rhythm-item">
          <span class="pg-rhythm-check"></span>
          <span>Listen to worship music</span>
        </div>
        <div class="pg-rhythm-item">
          <span class="pg-rhythm-check"></span>
          <span>Play with your kids without checking the clock</span>
        </div>
        <div class="pg-rhythm-item">
          <span class="pg-rhythm-check"></span>
          <span>Write a letter of encouragement to someone</span>
        </div>
      </div>
    </section>

    <blockquote class="pg-closing-quote">
      "Come to me, all who labor and are heavy laden, and I will give you rest."
      <cite>— Matthew 11:28</cite>
    </blockquote>

  </div>
</BaseLayout>

<style>
/* ── Page wrapper ──────────────────────────────────────────────── */
.pg-page {
  max-width: 860px;
  padding-top: 1.5rem;
}

/* ── Back link ─────────────────────────────────────────────────── */
.pg-back {
  display: inline-block;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 500;
  color: #9a8e82;
  text-decoration: none;
  margin-bottom: 1.75rem;
  letter-spacing: 0.01em;
  transition: color 0.15s;
}
.pg-back:hover { color: #b79c5c; }

/* ── Header ────────────────────────────────────────────────────── */
.pg-header { margin-bottom: 2rem; }
.pg-day-badge {
  display: inline-block;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #b79c5c;
  background: rgba(183, 156, 92, 0.1);
  border: 1px solid rgba(183, 156, 92, 0.3);
  padding: 0.22rem 0.65rem;
  border-radius: 2px;
  margin-bottom: 0.75rem;
}
.pg-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.9rem;
  font-weight: 700;
  color: #3d3830;
  margin: 0 0 0.3rem;
  line-height: 1.2;
}
.pg-subtitle {
  font-family: 'EB Garamond', serif;
  font-size: 1.05rem;
  font-style: italic;
  color: #7a7368;
  margin: 0 0 0.75rem;
  line-height: 1.6;
}
.pg-intro {
  font-family: 'EB Garamond', serif;
  font-size: 0.97rem;
  color: #5e554b;
  line-height: 1.7;
  margin: 0;
}

/* ── Time block header ─────────────────────────────────────────── */
.pg-time-block {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin: 1.75rem 0 0.85rem;
}
.pg-time-label {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #b79c5c;
  flex-shrink: 0;
}
.pg-time-icon {
  font-size: 0.75rem;
  color: #c2a86d;
}
.pg-time-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.2rem;
  font-weight: 700;
  color: #3d3830;
  margin: 0;
  flex: 1;
  padding-left: 0.75rem;
  border-left: 1px solid rgba(199, 187, 170, 0.5);
}

/* ── Sections ──────────────────────────────────────────────────── */
.pg-section {
  background: rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(199, 187, 170, 0.4);
  border-left: 3px solid #c2a86d;
  border-radius: 6px;
  padding: 1.4rem 1.5rem 1.2rem;
  margin-bottom: 0;
}
.pg-section--alt { background: rgba(233, 227, 216, 0.25); }
.pg-section-intro {
  font-family: 'EB Garamond', serif;
  font-size: 0.97rem;
  font-style: italic;
  color: #7a7368;
  margin: 0 0 1rem;
  line-height: 1.6;
}

/* ── Question list ─────────────────────────────────────────────── */
.pg-question-list { display: flex; flex-direction: column; gap: 0; }
.pg-question {
  padding: 0.85rem 0;
  border-bottom: 1px solid rgba(199, 187, 170, 0.22);
}
.pg-question:last-child { border-bottom: none; padding-bottom: 0; }
.pg-question p {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.88rem;
  color: #3d3830;
  line-height: 1.6;
  margin: 0 0 0.65rem;
  font-weight: 500;
}
.pg-question--prayer {
  background: rgba(183, 156, 92, 0.06);
  border-radius: 4px;
  padding: 0.85rem 1rem !important;
  margin: 0 -0.25rem;
}
.pg-prayer-prompt {
  font-family: 'EB Garamond', serif !important;
  font-style: italic;
  color: #5e554b !important;
  font-weight: 400 !important;
  font-size: 1rem !important;
  margin: 0 !important;
  line-height: 1.7 !important;
}

/* ── Write lines ───────────────────────────────────────────────── */
.pg-write-line {
  height: 1px;
  background: rgba(199, 187, 170, 0.5);
  margin: 0.55rem 0;
}

/* ── Section header ────────────────────────────────────────────── */
.pg-scripture-header {
  margin: 1.75rem 0 0.85rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid rgba(199, 187, 170, 0.4);
}
.pg-scripture-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.2rem;
  font-weight: 700;
  color: #3d3830;
  margin: 0;
}

/* ── Rhythm grid ───────────────────────────────────────────────── */
.pg-rhythm-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.5rem 1.5rem;
}
.pg-rhythm-item {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.86rem;
  color: #5e554b;
  line-height: 1.5;
  padding: 0.35rem 0;
  border-bottom: 1px solid rgba(199, 187, 170, 0.2);
}
.pg-rhythm-check {
  display: inline-block;
  width: 14px;
  height: 14px;
  border: 1.5px solid rgba(183, 156, 92, 0.55);
  border-radius: 2px;
  flex-shrink: 0;
}

/* ── Closing quote ─────────────────────────────────────────────── */
.pg-closing-quote {
  font-family: 'EB Garamond', serif;
  font-size: 1.08rem;
  font-style: italic;
  color: #7a7368;
  text-align: center;
  border: none;
  border-top: 1px solid rgba(199, 187, 170, 0.4);
  border-bottom: 1px solid rgba(199, 187, 170, 0.4);
  padding: 1.5rem 1rem;
  margin: 1.5rem 0 2.5rem;
  line-height: 1.75;
}
.pg-closing-quote cite {
  display: block;
  font-size: 0.82rem;
  font-style: normal;
  font-family: 'DM Sans', sans-serif;
  font-weight: 500;
  color: #b79c5c;
  margin-top: 0.5rem;
  letter-spacing: 0.04em;
}

/* ── Responsive ────────────────────────────────────────────────── */
@media (max-width: 640px) {
  .pg-title { font-size: 1.5rem; }
  .pg-section { padding: 1.1rem 1.1rem 1rem; }
  .pg-time-block { flex-direction: column; align-items: flex-start; gap: 0.4rem; }
  .pg-time-title { border-left: none; padding-left: 0; font-size: 1.1rem; }
  .pg-rhythm-grid { grid-template-columns: 1fr; }
}
</style>
