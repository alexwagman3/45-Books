---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Worship — Saturday: Praise"
  description="A gratitude inventory with 50 categories for thanksgiving, names and attributes of God, and postures of praise."
>
  <div class="takeaways-content pg-page">
    <a href="/worship/takeaways-weekly-prayer-plan/" class="pg-back">← Back to Weekly Prayer Plan</a>

    <div class="pg-header">
      <div class="pg-day-badge">Saturday · Praise</div>
      <h1 class="pg-title">Gratitude Inventory</h1>
      <p class="pg-subtitle">50 Categories for Thanksgiving</p>
    </div>

    <!-- DAILY PROVISIONS -->
    <section class="pg-section">
      <h2 class="pg-section-title">Daily Provisions</h2>
      <ol class="pg-list" start="1">
        <li>A roof over my head and a bed to sleep in</li>
        <li>Food on the table and clean water</li>
        <li>Clothes to wear and warmth in winter</li>
        <li>Health enough to do what today required</li>
        <li>Transportation to get where I needed to go</li>
        <li>Income or provision to meet my needs</li>
        <li>Safety through another day</li>
        <li>The ability to see, hear, taste, touch, smell</li>
        <li>A functioning body, even if imperfect</li>
        <li>Another day of life itself</li>
      </ol>
    </section>

    <!-- RELATIONSHIPS -->
    <section class="pg-section pg-section--alt">
      <h2 class="pg-section-title">Relationships</h2>
      <ol class="pg-list" start="11">
        <li>A spouse who walks with me through life</li>
        <li>Children who bring joy, challenge, and purpose</li>
        <li>Parents who sacrificed for me</li>
        <li>Siblings who share my history</li>
        <li>Friends who know me and love me anyway</li>
        <li>Extended family who shaped who I am</li>
        <li>A church family that supports me</li>
        <li>Neighbors who make where I live feel like home</li>
        <li>Colleagues who make work more bearable</li>
        <li>Even difficult relationships that refine me</li>
      </ol>
    </section>

    <!-- SPIRITUAL BLESSINGS -->
    <section class="pg-section">
      <h2 class="pg-section-title">Spiritual Blessings</h2>
      <ol class="pg-list" start="21">
        <li>Salvation and forgiveness of sins</li>
        <li>The indwelling Holy Spirit</li>
        <li>Access to God through prayer</li>
        <li>The Bible in my language</li>
        <li>Freedom to worship without persecution</li>
        <li>A church to belong to</li>
        <li>Spiritual growth over time</li>
        <li>Answered prayers, even the delayed ones</li>
        <li>God's discipline that proves His love</li>
        <li>The hope of eternity with Christ</li>
      </ol>
    </section>

    <!-- UNEXPECTED GIFTS -->
    <section class="pg-section pg-section--alt">
      <h2 class="pg-section-title">Unexpected Gifts</h2>
      <ol class="pg-list" start="31">
        <li>A kind word when I needed it most</li>
        <li>An unexpected provision or gift</li>
        <li>A problem that resolved better than expected</li>
        <li>A door that opened when another closed</li>
        <li>Clarity after a season of confusion</li>
        <li>A burden lifted unexpectedly</li>
        <li>Peace in the middle of chaos</li>
        <li>Strength I didn't know I had</li>
        <li>A second chance I didn't deserve</li>
        <li>A delay that turned out to be protection</li>
      </ol>
    </section>

    <!-- EVERYDAY GRACES -->
    <section class="pg-section">
      <h2 class="pg-section-title">Everyday Graces</h2>
      <ol class="pg-list" start="41">
        <li>The sound of my kids laughing</li>
        <li>A good night's sleep</li>
        <li>Music that moved my soul</li>
        <li>A meaningful text from a friend</li>
        <li>A task completed or goal achieved</li>
        <li>A moment of rest in a busy day</li>
        <li>Something that made me laugh out loud</li>
        <li>A meal that hit the spot</li>
        <li>The comfort of familiar routines</li>
        <li>Energy to be present with my family</li>
      </ol>
    </section>

    <!-- NAMES & ATTRIBUTES OF GOD -->
    <div class="pg-scripture-header">
      <h2 class="pg-scripture-title">Names &amp; Attributes of God</h2>
      <p class="pg-scripture-sub">A Guide for Praise</p>
    </div>

    <div class="pg-attr-grid">

      <div class="pg-attr-card">
        <span class="pg-attr-label">Who God Is in His Character</span>
        <ul class="pg-attr-list">
          <li><strong>Faithful</strong> — He keeps every promise He makes</li>
          <li><strong>Good</strong> — Everything He does flows from His goodness</li>
          <li><strong>Holy</strong> — He is set apart, pure, and perfect</li>
          <li><strong>Just</strong> — He always does what is right</li>
          <li><strong>Loving</strong> — His love is unconditional and unending</li>
          <li><strong>Merciful</strong> — He withholds the judgment we deserve</li>
          <li><strong>Gracious</strong> — He gives us blessings we don't deserve</li>
          <li><strong>Patient</strong> — He is slow to anger and abounding in love</li>
          <li><strong>Wise</strong> — His understanding is infinite</li>
          <li><strong>Sovereign</strong> — He is in control of all things</li>
        </ul>
      </div>

      <div class="pg-attr-card">
        <span class="pg-attr-label">Who God Is in His Relationship to Me</span>
        <ul class="pg-attr-list">
          <li><strong>Father</strong> — He adopts me and calls me His child</li>
          <li><strong>Friend</strong> — He draws near and invites intimacy</li>
          <li><strong>Shepherd</strong> — He leads, provides, and protects</li>
          <li><strong>Healer</strong> — He restores body, soul, and spirit</li>
          <li><strong>Refuge</strong> — He is my safe place in the storm</li>
          <li><strong>Deliverer</strong> — He rescues me from sin and death</li>
          <li><strong>Provider</strong> — He meets my every need</li>
          <li><strong>Comforter</strong> — He draws near in sorrow</li>
          <li><strong>Defender</strong> — He fights my battles for me</li>
          <li><strong>Redeemer</strong> — He buys me back and makes me new</li>
        </ul>
      </div>

    </div>

    <!-- NAMES OF GOD -->
    <section class="pg-section pg-section--alt">
      <h2 class="pg-section-label">Names of God to Declare</h2>
      <ul class="pg-names-list">
        <li><strong>Yahweh (LORD)</strong> — "I AM WHO I AM" — the self-existent, eternal God</li>
        <li><strong>El Shaddai</strong> — God Almighty, the all-sufficient One</li>
        <li><strong>Jehovah Jireh</strong> — The Lord Will Provide</li>
        <li><strong>Jehovah Rapha</strong> — The Lord Who Heals</li>
        <li><strong>Jehovah Shalom</strong> — The Lord Is Peace</li>
        <li><strong>Jehovah Nissi</strong> — The Lord Is My Banner (victory)</li>
        <li><strong>Jehovah Rohi</strong> — The Lord Is My Shepherd</li>
        <li><strong>Jehovah Tsidkenu</strong> — The Lord Our Righteousness</li>
        <li><strong>Jehovah Shammah</strong> — The Lord Is There (present)</li>
        <li><strong>El Roi</strong> — The God Who Sees Me</li>
      </ul>
    </section>

    <!-- POSTURES OF PRAISE -->
    <section class="pg-section">
      <h2 class="pg-section-label">Postures of Praise</h2>
      <ul class="pg-posture-list">
        <li>Lift your hands in surrender and adoration</li>
        <li>Kneel in reverence and humility</li>
        <li>Sing a hymn or worship song aloud</li>
        <li>Write out a psalm of your own</li>
        <li>Declare God's attributes out loud</li>
        <li>Take a walk and thank Him for creation</li>
        <li>Share what God has done with someone else</li>
      </ul>
    </section>

    <blockquote class="pg-closing-quote">
      "Give thanks to the Lord, for he is good; his love endures forever."
      <cite>— Psalm 107:1</cite>
    </blockquote>

  </div>
</BaseLayout>

<style>
/* ── Page wrapper ──────────────────────────────────────────────── */
.pg-page {
  max-width: 860px;
  padding-top: 1.5rem;
}

/* ── Back link ─────────────────────────────────────────────────── */
.pg-back {
  display: inline-block;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  font-weight: 500;
  color: #9a8e82;
  text-decoration: none;
  margin-bottom: 1.75rem;
  letter-spacing: 0.01em;
  transition: color 0.15s;
}
.pg-back:hover { color: #b79c5c; }

/* ── Header ────────────────────────────────────────────────────── */
.pg-header { margin-bottom: 2rem; }
.pg-day-badge {
  display: inline-block;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #b79c5c;
  background: rgba(183, 156, 92, 0.1);
  border: 1px solid rgba(183, 156, 92, 0.3);
  padding: 0.22rem 0.65rem;
  border-radius: 2px;
  margin-bottom: 0.75rem;
}
.pg-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.9rem;
  font-weight: 700;
  color: #3d3830;
  margin: 0 0 0.3rem;
  line-height: 1.2;
}
.pg-subtitle {
  font-family: 'EB Garamond', serif;
  font-size: 1.05rem;
  font-style: italic;
  color: #7a7368;
  margin: 0;
  line-height: 1.6;
}

/* ── Sections ──────────────────────────────────────────────────── */
.pg-section {
  background: rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(199, 187, 170, 0.4);
  border-left: 3px solid #c2a86d;
  border-radius: 6px;
  padding: 1.4rem 1.5rem 1.2rem;
  margin-bottom: 1rem;
}
.pg-section--alt { background: rgba(233, 227, 216, 0.25); }
.pg-section-title {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #b79c5c;
  margin: 0 0 1rem;
}
.pg-section-label {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #b79c5c;
  margin: 0 0 1rem;
}

/* ── Numbered list ─────────────────────────────────────────────── */
.pg-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.pg-list li {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.88rem;
  color: #5e554b;
  line-height: 1.6;
  padding: 0.55rem 0;
  border-bottom: 1px solid rgba(199, 187, 170, 0.22);
  display: flex;
  gap: 0.75rem;
  align-items: baseline;
  counter-increment: list-counter;
}
.pg-list li:last-child { border-bottom: none; padding-bottom: 0; }
ol.pg-list { counter-reset: list-counter attr(start) -1; }
.pg-list li::before {
  content: counter(list-counter, decimal-leading-zero);
  font-family: 'DM Sans', sans-serif;
  font-size: 0.65rem;
  font-weight: 700;
  color: #c2a86d;
  min-width: 1.6rem;
  flex-shrink: 0;
}

/* ── Section header ────────────────────────────────────────────── */
.pg-scripture-header {
  margin: 2rem 0 1.25rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid rgba(199, 187, 170, 0.4);
}
.pg-scripture-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.25rem;
  font-weight: 700;
  color: #3d3830;
  margin: 0 0 0.2rem;
}
.pg-scripture-sub {
  font-family: 'EB Garamond', serif;
  font-size: 0.97rem;
  font-style: italic;
  color: #7a7368;
  margin: 0;
}

/* ── Attributes grid ───────────────────────────────────────────── */
.pg-attr-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
  margin-bottom: 1rem;
}
.pg-attr-card {
  background: rgba(255, 255, 255, 0.55);
  border: 1px solid rgba(199, 187, 170, 0.4);
  border-top: 3px solid #c2a86d;
  border-radius: 5px;
  padding: 1.1rem 1.2rem;
}
.pg-attr-label {
  display: block;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #b79c5c;
  margin-bottom: 0.75rem;
}
.pg-attr-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.pg-attr-list li {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.85rem;
  color: #5e554b;
  line-height: 1.55;
  padding: 0.45rem 0;
  border-bottom: 1px solid rgba(199, 187, 170, 0.2);
}
.pg-attr-list li:last-child { border-bottom: none; padding-bottom: 0; }
.pg-attr-list strong {
  color: #3d3830;
  font-weight: 600;
}

/* ── Names list ────────────────────────────────────────────────── */
.pg-names-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
}
.pg-names-list li {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.87rem;
  color: #5e554b;
  line-height: 1.6;
  padding: 0.5rem 0;
  border-bottom: 1px solid rgba(199, 187, 170, 0.22);
}
.pg-names-list li:last-child { border-bottom: none; padding-bottom: 0; }
.pg-names-list strong { color: #3d3830; font-weight: 600; }

/* ── Posture list ──────────────────────────────────────────────── */
.pg-posture-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
}
.pg-posture-list li {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.88rem;
  color: #5e554b;
  line-height: 1.6;
  padding: 0.5rem 0 0.5rem 1.1rem;
  border-bottom: 1px solid rgba(199, 187, 170, 0.22);
  position: relative;
}
.pg-posture-list li:last-child { border-bottom: none; }
.pg-posture-list li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: #c2a86d;
  font-weight: 600;
}

/* ── Closing quote ─────────────────────────────────────────────── */
.pg-closing-quote {
  font-family: 'EB Garamond', serif;
  font-size: 1.08rem;
  font-style: italic;
  color: #7a7368;
  text-align: center;
  border: none;
  border-top: 1px solid rgba(199, 187, 170, 0.4);
  border-bottom: 1px solid rgba(199, 187, 170, 0.4);
  padding: 1.5rem 1rem;
  margin: 0 0 2.5rem;
  line-height: 1.75;
}
.pg-closing-quote cite {
  display: block;
  font-size: 0.82rem;
  font-style: normal;
  font-family: 'DM Sans', sans-serif;
  font-weight: 500;
  color: #b79c5c;
  margin-top: 0.5rem;
  letter-spacing: 0.04em;
}

/* ── Responsive ────────────────────────────────────────────────── */
@media (max-width: 640px) {
  .pg-title { font-size: 1.5rem; }
  .pg-section { padding: 1.1rem 1.1rem 1rem; }
  .pg-attr-grid { grid-template-columns: 1fr; }
}
</style>
