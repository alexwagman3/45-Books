}
.pg-r-prayer {
  font-family: 'EB Garamond', serif;
  font-size: 1rem;
  font-style: italic;
  color: #5e554b;
  line-height: 1.75;
  margin: 0;
}
.pg-blank {
  font-style: normal;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 600;
  color: #b79c5c;
  border-bottom: 1.5px solid #c2a86d;
  padding-bottom: 1px;
  letter-spacing: 0.08em;
}

/* ── Section header ────────────────────────────────────────────── */
.pg-scripture-header {
  margin: 0 0 1.25rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid rgba(199, 187, 170, 0.4);
}
.pg-scripture-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.25rem;
  font-weight: 700;
  color: #3d3830;
  margin: 0 0 0.2rem;
}
.pg-scripture-sub {
  font-family: 'EB Garamond', serif;
