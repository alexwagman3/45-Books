  margin-bottom: 0.75rem;
}
.pg-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.9rem;
  font-weight: 700;
  color: #3d3830;
  margin: 0 0 0.3rem;
  line-height: 1.2;
}

/* ── 6 R's stack ───────────────────────────────────────────────── */
.pg-six-r-stack {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin-bottom: 2rem;
}
.pg-r-card {
  display: flex;
  gap: 1.25rem;
  align-items: flex-start;
