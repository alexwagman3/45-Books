  line-height: 1;
  flex-shrink: 0;
  min-width: 1.4rem;
  margin-top: 0.1rem;
}
.pg-r-number--praise {
  color: rgba(183, 156, 92, 0.6);
}
.pg-r-body { flex: 1; }
.pg-r-title {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.88rem;
  font-weight: 700;
  color: #3d3830;
  margin: 0 0 0.65rem;
  line-height: 1.3;
}
.pg-r-sub {
  font-weight: 400;
