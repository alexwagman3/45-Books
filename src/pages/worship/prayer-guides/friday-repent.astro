  font-size: 0.65rem;
  font-weight: 700;
  color: #c2a86d;
  min-width: 1.6rem;
  flex-shrink: 0;
}

/* ── Closing quote ─────────────────────────────────────────────── */
.pg-closing-quote {
  font-family: 'EB Garamond', serif;
  font-size: 1.08rem;
  font-style: italic;
  color: #7a7368;
  text-align: center;
  border: none;
  border-top: 1px solid rgba(199, 187, 170, 0.4);
  border-bottom: 1px solid rgba(199, 187, 170, 0.4);
  padding: 1.5rem 1rem;
  margin: 0 0 2.5rem;
  line-height: 1.75;
}
.pg-closing-quote cite {
  display: block;
  font-size: 0.82rem;
  font-style: normal;
  font-family: 'DM Sans', sans-serif;
  font-weight: 500;
  color: #b79c5c;
