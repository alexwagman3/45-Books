  text-transform: uppercase;
  color: #b79c5c;
  margin: 0 0 1rem;
}

/* ── Numbered list ─────────────────────────────────────────────── */
.pg-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.pg-list li {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.88rem;
  color: #5e554b;
  line-height: 1.6;
  padding: 0.55rem 0;
  border-bottom: 1px solid rgba(199, 187, 170, 0.22);
