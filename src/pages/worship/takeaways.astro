---
import BaseLayout from '../../layouts/BaseLayout.astro';

const books = [
  { slug: 'called-to-worship',          title: 'Called to Worship' },
  { slug: 'sacred-pathways',            title: 'Sacred Pathways' },
  { slug: 'the-battle-plan-for-prayer', title: 'The Battle Plan for Prayer' },
];
---

<BaseLayout
  title="Worship — Personal Takeaways"
  description="Personal takeaways from the Worship shelf: a weekly prayer plan that rotates through seven distinct postures to build a complete prayer life."
>
  <a class="overlay-back" href="/">&#8592; Back to Bookshelf</a>
  <a class="overlay-close" href="/" aria-label="Close">&times;</a>

  <div class="takeaways-content">
    <span class="takeaways-tag">Worship</span>
    <h1 class="takeaways-title">Weekly Prayer Plan</h1>
    <p class="takeaways-author" style="margin-bottom: 0.5rem;">Personal Takeaways</p>

    <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:2rem;">
      {books.map((b) => (
        <a href={`/books/${b.slug}/`} class="overlay-takeaways-btn" style="font-size:0.78rem; padding:0.35rem 0.9rem;">
          {b.title}
        </a>
      ))}
    </div>

    <div class="tk-section">
      <div class="tk-section-title">Weekly Prayer Plan</div>
      <p style="font-family:'EB Garamond',serif;font-size:.95rem;color:#5E554B;line-height:1.8;margin-bottom:1rem">Most people pray when they feel like it, about what's front of mind, in whatever form comes naturally. Thomas showed me that different postures of worship feed different parts of the soul. So I built a weekly plan that rotates through seven distinct modes: Monday to ask, Tuesday to study, Wednesday to intercede, Thursday to bless, Friday to repent, Saturday to praise, and Sunday to meditate. Each day carries a different orientation — not because God requires variety, but because I do. Asking alone produces neediness. Praise alone produces sentimentality. Repentance alone produces shame. Intercession alone produces exhaustion. Together, across a week, they produce a complete prayer life that engages the mind, humbles the heart, and expands your view of God beyond what any single posture can accomplish on its own. The plan takes about 15 minutes a day. The reflection questions keep it engaging. The structure keeps it consistent. The goal isn't to complete the plan — it's to show up to God every day in a posture that makes you more available to Him.</p>
      <a class="go-deeper-btn" href="/worship/takeaways-weekly-prayer-plan/">See Full Weekly Prayer Plan &rarr;</a>
    </div>
  </div>
</BaseLayout>

<style>
  html { scroll-behavior: smooth; }
</style>
