---
import BaseLayout from '../../layouts/BaseLayout.astro';

const books = [
  { slug: 'emotional-first-aid', title: 'Emotional First Aid' },
  { slug: 'untangling-emotions', title: 'Untangling Emotions' },
  { slug: 'if-youre-so-smart',   title: "If You're So Smart Then Why Aren't You Happy?" },
];
---

<BaseLayout
  title="Manage Your Emotions — Personal Takeaways"
  description="Personal takeaways from the Manage Your Emotions shelf: Emotional First Aid, Untangling Emotions, and If You're So Smart Then Why Aren't You Happy?"
>
  <a class="overlay-back" href="/">&#8592; Back to Bookshelf</a>
  <a class="overlay-close" href="/" aria-label="Close">&times;</a>

  <div class="takeaways-content">
    <span class="takeaways-tag">Manage Your Emotions</span>
    <h1 class="takeaways-title">Manage Your Emotions</h1>
    <p class="takeaways-author" style="margin-bottom: 0.5rem;">Personal Takeaways</p>

    <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:2rem;">
      {books.map((b) => (
        <a href={`/books/${b.slug}/`} class="overlay-takeaways-btn" style="font-size:0.78rem; padding:0.35rem 0.9rem;">
          {b.title}
        </a>
      ))}
    </div>

    <div class="overlay-coming-soon">
      Personal takeaways for this shelf haven't been added yet. Check back soon.
    </div>
  </div>
</BaseLayout>

<style>
  html { scroll-behavior: smooth; }
</style>
