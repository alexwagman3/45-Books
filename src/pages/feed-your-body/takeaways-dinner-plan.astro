---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Feed Your Body — Weekly Dinner Plan"
  description="Deep dive: a full weekly dinner rotation with ingredients and step-by-step cooking instructions, plus lunch options."
  canonicalPath="/feed-your-body/takeaways-dinner-plan/"
>
  <a class="overlay-back" href="/feed-your-body/takeaways/">&#8592; Back to Takeaways</a>
  <a class="overlay-close" href="/" aria-label="Close">&times;</a>

  <div class="takeaways-content dp-wrap">

    <span class="takeaways-tag">Feed Your Body</span>
    <h1 class="takeaways-title">Weekly Dinner Plan</h1>

    <nav class="dp-nav">
      <a class="dp-nav-link" href="#week1">Week 1</a>
      <a class="dp-nav-link" href="#week2">Week 2</a>
      <a class="dp-nav-link" href="#lunch">Lunch Options</a>
    </nav>

    <!-- ═══════════════════════════════════════════ WEEK 1 ══ -->
    <section class="dp-week" id="week1">
      <h2 class="dp-week-title">Week 1</h2>

      <div class="dp-grid">

        <!-- MON -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Monday</span>
            <h3 class="dp-meal">Chicken + Broccoli + Sweet Potato</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~10–15 min</span>
            <span class="dp-stat"><em>Cal</em> 550 kcal</span>
            <span class="dp-stat"><em>Macros</em> 40P · 35C · 25F</span>
            <span class="dp-stat"><em>Cost</em> $4–$6</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>Chicken thighs, broccoli, sweet potato fries</li>
                <li>Mexican cheese, breadcrumbs, garlic</li>
                <li>Cumin, onion powder, smoked paprika, lemon pepper</li>
                <li>EVOO, salt, pepper</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Preheat grill + oven 425°F. Season chicken with spices. Toss broccoli with EVOO + seasonings.</li>
                <li>Grill chicken ~18 min (flip once) to 165°F internal.</li>
                <li>Roast broccoli 22 min at 425°F; top with cheese + breadcrumbs, broil 2 min. (Alt: air-fry 390°F, 6 min.)</li>
                <li>Air-fry sweet potato fries 400°F, 10–12 min, shake halfway.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- TUE -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Tuesday</span>
            <h3 class="dp-meal">Chicken Tortilla Soup</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~15–20 min</span>
            <span class="dp-stat"><em>Cal</em> 450 kcal</span>
            <span class="dp-stat"><em>Macros</em> 35P · 45C · 15F</span>
            <span class="dp-stat"><em>Cost</em> $4–$5</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>Chicken, broth, fire-roasted tomatoes</li>
                <li>Beans, corn, green chilies, onion, garlic</li>
                <li>Avocado, tortilla strips, cilantro, cheese</li>
                <li>Jalapeños, sour cream, lime, cumin, chili powder, paprika</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Sauté onion + garlic; add cumin, chili powder, and paprika.</li>
                <li>Add tomatoes + broth; simmer 10 min. Add chicken, beans, corn, and chilies; cook 10–15 min.</li>
                <li>Shred chicken in pot. Serve topped with tortilla strips, avocado, cheese, jalapeño, cilantro, sour cream, and lime.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- WED -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Wednesday</span>
            <h3 class="dp-meal">Salmon + Asparagus + Zucchini</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~15 min</span>
            <span class="dp-stat"><em>Cal</em> 500 kcal</span>
            <span class="dp-stat"><em>Macros</em> 35P · 10C · 30F</span>
            <span class="dp-stat"><em>Cost</em> $8–$12</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>Salmon, asparagus, zucchini</li>
                <li>Garlic, butter, lemon, EVOO</li>
                <li>Tony's Cajun, red pepper flakes, salt/pepper</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Pan-sear salmon skin-down 4–5 min, flip 1–3 min. (Alt: bake 375°F, 16 min thawed / 29 min frozen; target 135°F.)</li>
                <li>Roast asparagus 425°F, 12 min; finish with lemon + optional parmesan for 1 min.</li>
                <li>Sear zucchini on hot cast iron 3–5 min per side; finish with butter + lemon.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- THU -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Thursday</span>
            <h3 class="dp-meal">Spaghetti + Green Beans</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~15–20 min</span>
            <span class="dp-stat"><em>Cal</em> 600 kcal</span>
            <span class="dp-stat"><em>Macros</em> 35P · 65C · 20F</span>
            <span class="dp-stat"><em>Cost</em> $3–$5</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>Whole wheat thin spaghetti, 93/7 lean ground beef</li>
                <li>Marinara sauce, garlic, onion (opt), EVOO</li>
                <li>Green beans, butter, salt/pepper, garlic powder (opt)</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Boil salted water; cook pasta 7–9 min, drain.</li>
                <li>Sauté onion 3–4 min, add garlic 30 sec. Brown beef 6–8 min; add marinara, simmer 5–10 min.</li>
                <li>Green beans (Instant Pot): steam 3 min high pressure, quick release. Toss with butter + salt/pepper.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- FRI -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Friday</span>
            <h3 class="dp-meal">Tilapia + Peas + Carrots</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~10 min</span>
            <span class="dp-stat"><em>Cal</em> 350 kcal</span>
            <span class="dp-stat"><em>Macros</em> 30P · 30C · 10F</span>
            <span class="dp-stat"><em>Cost</em> $4–$6</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>Tilapia, peas, carrots</li>
                <li>Honey, thyme, garlic, lemon</li>
                <li>Butter, olive oil, salt/pepper</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Thaw fish, pat dry, season; air-fry 360°F for 12 min to 145°F. Rest 2 min.</li>
                <li>Bake carrots 425°F ~18 min; finish with honey + butter; add peas for last 4 min. (Alt: Instant Pot 1 min.)</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- SAT -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Saturday</span>
            <h3 class="dp-meal">Shrimp + Okra Gumbo</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~20–25 min</span>
            <span class="dp-stat"><em>Cal</em> 450 kcal</span>
            <span class="dp-stat"><em>Macros</em> 30P · 55C · 12F</span>
            <span class="dp-stat"><em>Cost</em> $6–$8</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>Shrimp, smoked sausage (opt), okra</li>
                <li>Bell pepper, onion, celery, garlic, brown rice</li>
                <li>Diced tomatoes, chicken broth, Worcestershire, bay leaf</li>
                <li>EVOO, smoked paprika, thyme, oregano, cayenne, salt/pepper</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Brown rice (Instant Pot): 1 cup rice + 1¼ cups water + salt. High pressure 22 min, release, fluff.</li>
                <li>Sauté onion, pepper, and celery 5–7 min; add garlic + spices 1 min.</li>
                <li>Add okra + tomatoes 5 min; add broth + Worcestershire; simmer 15–20 min.</li>
                <li>Add shrimp 3–4 min until pink. Remove bay leaf; serve over rice.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- SUN -->
        <article class="dp-card dp-card--full">
          <div class="dp-card-head">
            <span class="dp-day">Sunday</span>
            <h3 class="dp-meal">Carne Asada Street Tacos</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~20–25 min + marinate</span>
            <span class="dp-stat"><em>Cal</em> 650 kcal</span>
            <span class="dp-stat"><em>Macros</em> 40P · 50C · 30F</span>
            <span class="dp-stat"><em>Cost</em> $8–$10</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>NY strip or flat iron steak (~1 lb), small corn tortillas, charro beans</li>
                <li>Lime, orange, soy sauce, EVOO, garlic, cilantro</li>
                <li>Cumin, chili powder, paprika, salt/pepper</li>
                <li>Onion, jalapeño, salsa verde, queso fresco</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Marinate: lime + orange juice, soy sauce, oil, garlic, cilantro + dry spices. 30 min to 2 hrs.</li>
                <li>Sous vide at 128°F for 2 hours, then grill steak 3 min each side to 135°F; rest 5 min, then chop.</li>
                <li>Warm tortillas; top with steak, onion, jalapeño, cilantro, salsa, and cheese. Serve with beans.</li>
              </ol>
            </div>
          </div>
        </article>

      </div><!-- .dp-grid -->
    </section>

    <!-- ═══════════════════════════════════════════ WEEK 2 ══ -->
    <section class="dp-week" id="week2">
      <h2 class="dp-week-title">Week 2</h2>

      <div class="dp-grid">

        <!-- MON -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Monday</span>
            <h3 class="dp-meal">Beef &amp; Vegetable Stir Fry</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~20–25 min</span>
            <span class="dp-stat"><em>Cal</em> 450 kcal</span>
            <span class="dp-stat"><em>Macros</em> 35P · 50C · 15F</span>
            <span class="dp-stat"><em>Cost</em> $5–$7</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>1 lb flank or sirloin steak, thinly sliced</li>
                <li>Broccoli, snap peas, bell pepper, mushrooms</li>
                <li>Garlic, ginger, green onion</li>
                <li>Soy sauce, hoisin, sesame oil, cornstarch</li>
                <li>Brown rice for serving</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Toss sliced beef with 1 tbsp soy sauce + 1 tsp cornstarch; marinate 10 min.</li>
                <li>Whisk sauce: 3 tbsp soy sauce, 2 tbsp hoisin, 1 tsp sesame oil, 1 tbsp water.</li>
                <li>Sear beef in very hot skillet 1–2 min; set aside. Cook vegetables 4–5 min.</li>
                <li>Return beef; add sauce + garlic + ginger; toss 1 min. Serve over rice, top with green onion.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- TUE -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Tuesday</span>
            <h3 class="dp-meal">Salsa Verde Chicken Bowl</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~10–15 min + slow cook</span>
            <span class="dp-stat"><em>Cal</em> 500 kcal</span>
            <span class="dp-stat"><em>Macros</em> 40P · 55C · 15F</span>
            <span class="dp-stat"><em>Cost</em> $3–$5</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>1.5 lbs chicken thighs or breasts</li>
                <li>1 large jar salsa verde (green salsa)</li>
                <li>Brown rice, canned black beans</li>
                <li>Avocado, sour cream (opt), cilantro</li>
                <li>Salt/pepper, lime</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Add chicken + entire jar of salsa verde to slow cooker. Cook on low 6–8 hrs or high 3–4 hrs.</li>
                <li>Shred chicken directly in pot; stir to coat with sauce.</li>
                <li>Cook brown rice per package instructions. Warm drained black beans in a small pot.</li>
                <li>Build bowl: rice &rarr; beans &rarr; chicken &rarr; avocado. Squeeze lime, top with cilantro.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- WED -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Wednesday</span>
            <h3 class="dp-meal">Beef Barley Stew</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~15–20 min</span>
            <span class="dp-stat"><em>Cal</em> 400 kcal</span>
            <span class="dp-stat"><em>Macros</em> 30P · 50C · 12F</span>
            <span class="dp-stat"><em>Cost</em> $4–$6</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>1.5 lbs beef stew meat, cubed</li>
                <li>Pearl barley (¾ cup), carrots, celery, onion</li>
                <li>Mushrooms, garlic, diced tomatoes (1 can)</li>
                <li>Beef broth (4 cups), Worcestershire, tomato paste</li>
                <li>Thyme, rosemary, bay leaf, salt/pepper, EVOO</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Season and sear beef in EVOO until browned on all sides; set aside.</li>
                <li>Sauté onion, carrots, and celery 5 min. Add garlic + tomato paste 1 min.</li>
                <li>Return beef; add broth, tomatoes, barley, Worcestershire, and herbs. Bring to a boil.</li>
                <li>Simmer covered 45–55 min until barley is tender and beef is fork-soft. Remove bay leaf; adjust seasoning.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- THU -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Thursday</span>
            <h3 class="dp-meal">Greek Chickpea Salad</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~15 min</span>
            <span class="dp-stat"><em>Cal</em> 400 kcal</span>
            <span class="dp-stat"><em>Macros</em> 15P · 45C · 20F</span>
            <span class="dp-stat"><em>Cost</em> $3–$4</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>2 cans chickpeas, drained &amp; rinsed</li>
                <li>Cucumber, cherry tomatoes, red onion</li>
                <li>Kalamata olives, feta cheese</li>
                <li>Fresh parsley or mint</li>
                <li>EVOO, red wine vinegar, lemon, dried oregano, salt/pepper</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Dice cucumber, halve tomatoes, thinly slice red onion. Combine in a large bowl with chickpeas, olives, and parsley.</li>
                <li>Whisk together 3 tbsp EVOO, 2 tbsp red wine vinegar, juice of 1 lemon, 1 tsp oregano, salt + pepper.</li>
                <li>Pour dressing over salad; toss well. Crumble feta on top. Refrigerate 15 min before serving.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- FRI -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Friday</span>
            <h3 class="dp-meal">Sweet Potato Turkey Skillet</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~20 min</span>
            <span class="dp-stat"><em>Cal</em> 450 kcal</span>
            <span class="dp-stat"><em>Macros</em> 30P · 40C · 18F</span>
            <span class="dp-stat"><em>Cost</em> $3–$5</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>1 lb ground turkey (93/7)</li>
                <li>2 medium sweet potatoes, cubed small</li>
                <li>Bell pepper, onion, baby spinach</li>
                <li>Garlic, smoked paprika, cumin, chili powder</li>
                <li>EVOO, chicken broth (¼ cup), salt/pepper, hot sauce (opt)</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Microwave cubed sweet potato 4–5 min to par-cook. Season turkey with spices.</li>
                <li>Brown turkey in skillet over medium-high heat 6–8 min, breaking apart; set aside.</li>
                <li>Sauté onion + bell pepper 3–4 min. Add garlic 30 sec. Add sweet potato + broth; cover 5 min until tender.</li>
                <li>Return turkey; fold in spinach until wilted. Adjust seasoning. Serve with hot sauce if desired.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- SAT -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Saturday</span>
            <h3 class="dp-meal">Shrimp Fried Rice</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~20 min</span>
            <span class="dp-stat"><em>Cal</em> 450 kcal</span>
            <span class="dp-stat"><em>Macros</em> 30P · 50C · 12F</span>
            <span class="dp-stat"><em>Cost</em> $5–$7</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>1 lb shrimp, peeled &amp; deveined</li>
                <li>1 cup cooked brown rice (day-old preferred)</li>
                <li>Broccoli, bell pepper, snap peas, carrots</li>
                <li>3 eggs, garlic, ginger (fresh or paste)</li>
                <li>Soy sauce, sesame oil, oyster sauce (opt), green onion</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Season shrimp with salt + pepper. Sauté in hot wok/skillet 1–2 min per side; set aside.</li>
                <li>Add garlic + ginger; stir 30 sec. Add vegetables; cook 4–5 min until tender-crisp.</li>
                <li>Push veggies aside; scramble eggs in the pan. Combine everything.</li>
                <li>Add rice; stir-fry 2–3 min. Add shrimp back. Season with soy sauce + sesame oil. Top with green onion.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- SUN -->
        <article class="dp-card dp-card--full">
          <div class="dp-card-head">
            <span class="dp-day">Sunday</span>
            <h3 class="dp-meal">White Bean Pasta</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~15–20 min</span>
            <span class="dp-stat"><em>Cal</em> 480 kcal</span>
            <span class="dp-stat"><em>Macros</em> 20P · 70C · 15F</span>
            <span class="dp-stat"><em>Cost</em> $2–$4</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>Whole wheat pasta (8 oz)</li>
                <li>2 cans white beans, drained</li>
                <li>Baby spinach or kale, cherry tomatoes</li>
                <li>Garlic (4–5 cloves), red pepper flakes</li>
                <li>EVOO, lemon, parmesan, salt/pepper, fresh basil (opt)</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Cook pasta per package instructions; reserve ½ cup pasta water before draining.</li>
                <li>Sauté garlic + red pepper flakes in generous EVOO 1–2 min. Add tomatoes; cook until blistered, 4–5 min.</li>
                <li>Add beans; mash about ¼ of them for creaminess. Add spinach; wilt 1–2 min.</li>
                <li>Toss in pasta + splash of pasta water; squeeze lemon. Finish with parmesan + basil.</li>
              </ol>
            </div>
          </div>
        </article>

      </div><!-- .dp-grid -->
    </section>

    <!-- ══════════════════════════════════════ LUNCH OPTIONS ══ -->
    <section class="dp-week" id="lunch">
      <h2 class="dp-week-title">Lunch Options</h2>

      <div class="dp-lunch-grid">
        <div class="dp-lunch-card">
          <div class="dp-lunch-title">Go-To Picks</div>
          <ul>
            <li>Fruit (apple / berries / citrus / kiwi)</li>
            <li>Veg + hummus</li>
            <li>Kimchi, kefir</li>
            <li>Prepared salads (orzo / kale)</li>
            <li>Nuggets / wings / dumplings</li>
            <li>Avocado turkey sandwich</li>
          </ul>
        </div>

        <div class="dp-lunch-card">
          <div class="dp-lunch-title">Grab &amp; Go</div>
          <ul>
            <li>Turkey slices, summer sausage, turkey sticks</li>
            <li>Tuna + crackers</li>
            <li>Pumpkin seeds, pistachios, trail mix</li>
            <li>IQBar, Alyssa's bites</li>
            <li>Poshi olives</li>
          </ul>
        </div>

        <div class="dp-lunch-card">
          <div class="dp-lunch-title">Pre-Dinner Protein</div>
          <ul>
            <li>Momentous 20g protein in water</li>
          </ul>
        </div>
      </div>
    </section>

  </div><!-- .dp-wrap -->
</BaseLayout>

<style>
/* ── Page wrapper ─────────────────────────────────────────────── */
.dp-wrap {
  max-width: 1080px;
