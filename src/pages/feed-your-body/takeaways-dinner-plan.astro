---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Feed Your Body — Weekly Dinner Plan"
  description="Deep dive: a full weekly dinner rotation with ingredients and step-by-step cooking instructions, plus lunch options."
  canonicalPath="/feed-your-body/takeaways-dinner-plan/"
>
  <a class="overlay-back" href="/feed-your-body/takeaways/">&#8592; Back to Takeaways</a>
  <a class="overlay-close" href="/" aria-label="Close">&times;</a>

  <div class="takeaways-content dp-wrap">

    <span class="takeaways-tag">Feed Your Body</span>
    <h1 class="takeaways-title">Weekly Dinner Plan</h1>

    <!-- ═══════════════════════════════════════════ WEEK 1 ══ -->
    <section class="dp-week" id="week1">
      <h2 class="dp-week-title">Week 1</h2>

      <div class="dp-grid">

        <!-- MON -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Monday</span>
            <h3 class="dp-meal">Chicken + Broccoli + Sweet Potato</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~10–15 min</span>
            <span class="dp-stat"><em>Cal</em> 550 kcal</span>
            <span class="dp-stat"><em>Macros</em> 40P · 35C · 25F</span>
            <span class="dp-stat"><em>Cost</em> $4–$6</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>Chicken thighs</li>
                <li>Broccoli</li>
                <li>Sweet potato fries, Mexican cheese, breadcrumbs, garlic</li>
                <li>EVOO, cumin, onion powder, smoked paprika, lemon pepper, salt, pepper</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Preheat grill + oven 425°F. Season chicken with spices. Toss broccoli with EVOO + seasonings.</li>
                <li>Grill chicken ~18 min (flip once) to 165°F internal.</li>
                <li>Roast broccoli 22 min at 425°F; top with cheese + breadcrumbs, broil 2 min. (Alt: air-fry 390°F, 6 min.)</li>
                <li>Air-fry sweet potato fries 400°F, 10–12 min, shake halfway.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- TUE -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Tuesday</span>
            <h3 class="dp-meal">Chicken Tortilla Soup</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~15–20 min</span>
            <span class="dp-stat"><em>Cal</em> 450 kcal</span>
            <span class="dp-stat"><em>Macros</em> 35P · 45C · 15F</span>
            <span class="dp-stat"><em>Cost</em> $4–$5</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>Chicken</li>
                <li>Onion, garlic, corn, green chilies, jalapeños, cilantro, avocado, lime</li>
                <li>Broth, fire-roasted tomatoes, beans, tortilla strips, cheese, sour cream</li>
                <li>Cumin, chili powder, paprika</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Sauté onion + garlic; add cumin, chili powder, and paprika.</li>
                <li>Add tomatoes + broth; simmer 10 min. Add chicken, beans, corn, and chilies; cook 10–15 min.</li>
                <li>Shred chicken in pot. Serve topped with tortilla strips, avocado, cheese, jalapeño, cilantro, sour cream, and lime.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- WED -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Wednesday</span>
            <h3 class="dp-meal">Salmon + Asparagus + Zucchini</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~15 min</span>
            <span class="dp-stat"><em>Cal</em> 500 kcal</span>
            <span class="dp-stat"><em>Macros</em> 35P · 10C · 30F</span>
            <span class="dp-stat"><em>Cost</em> $8–$12</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>Salmon</li>
                <li>Asparagus, zucchini, garlic</li>
                <li>Lemon</li>
                <li>Butter, EVOO, Tony's Cajun, red pepper flakes, salt/pepper</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Pan-sear salmon skin-down 4–5 min, flip 1–3 min. (Alt: bake 375°F, 16 min thawed / 29 min frozen; target 135°F.)</li>
                <li>Roast asparagus 425°F, 12 min; finish with lemon + optional parmesan for 1 min.</li>
                <li>Sear zucchini on hot cast iron 3–5 min per side; finish with butter + lemon.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- THU -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Thursday</span>
            <h3 class="dp-meal">Spaghetti + Green Beans</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~15–20 min</span>
            <span class="dp-stat"><em>Cal</em> 600 kcal</span>
            <span class="dp-stat"><em>Macros</em> 35P · 65C · 20F</span>
            <span class="dp-stat"><em>Cost</em> $3–$5</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>93/7 lean ground beef</li>
                <li>Green beans, garlic, onion (opt)</li>
                <li>Whole wheat thin spaghetti, marinara sauce</li>
                <li>EVOO, butter, garlic powder (opt), salt/pepper</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Boil salted water; cook pasta 7–9 min, drain.</li>
                <li>Sauté onion 3–4 min, add garlic 30 sec. Brown beef 6–8 min; add marinara, simmer 5–10 min.</li>
                <li>Green beans (Instant Pot): steam 3 min high pressure, quick release. Toss with butter + salt/pepper.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- FRI -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Friday</span>
            <h3 class="dp-meal">Tilapia + Peas + Carrots</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~10 min</span>
            <span class="dp-stat"><em>Cal</em> 350 kcal</span>
            <span class="dp-stat"><em>Macros</em> 30P · 30C · 10F</span>
            <span class="dp-stat"><em>Cost</em> $4–$6</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>Frozen Boneless Skinless Tilapia Fillets</li>
                <li>Peas, carrots, garlic, lemon</li>
                <li>Panko breadcrumbs, grated Parmesan</li>
                <li>Butter, olive oil, paprika, garlic powder, thyme, salt/pepper</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Rinse fillets under cool water to remove surface ice, pat dry, and season with paprika, garlic powder, thyme, lemon zest, salt, and pepper.</li>
                <li>Brush tops with olive oil + melted butter, press on a panko-Parmesan crust, then air-fry at 390°F for 10–12 min until the crust is golden and fish reaches 145°F. Rest 2 min.</li>
                <li>Bake carrots 425°F ~18 min; add peas for last 4 min and finish with butter, garlic, and lemon juice.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- SAT -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Saturday</span>
            <h3 class="dp-meal">Shrimp + Okra Gumbo</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~20–25 min</span>
            <span class="dp-stat"><em>Cal</em> 450 kcal</span>
            <span class="dp-stat"><em>Macros</em> 30P · 55C · 12F</span>
            <span class="dp-stat"><em>Cost</em> $6–$8</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>Shrimp, chicken sausage (opt)</li>
                <li>Okra, bell pepper, onion, celery, garlic</li>
                <li>Diced tomatoes, chicken broth, Worcestershire, bay leaf</li>
                <li>Brown rice, EVOO, smoked paprika, thyme, oregano, cayenne, salt/pepper</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Brown rice (Instant Pot): 1 cup rice + 1¼ cups water + salt. High pressure 22 min, release, fluff.</li>
                <li>Sauté onion, pepper, and celery 5–7 min; add garlic + spices 1 min.</li>
                <li>Add okra + tomatoes 5 min; add broth + Worcestershire; simmer 15–20 min.</li>
                <li>Add shrimp 3–4 min until pink. Remove bay leaf; serve over rice.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- SUN -->
        <article class="dp-card dp-card--full">
          <div class="dp-card-head">
            <span class="dp-day">Sunday</span>
            <h3 class="dp-meal">Carne Asada Street Tacos</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~20–25 min + marinate</span>
            <span class="dp-stat"><em>Cal</em> 650 kcal</span>
            <span class="dp-stat"><em>Macros</em> 40P · 50C · 30F</span>
            <span class="dp-stat"><em>Cost</em> $8–$10</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>Flat iron steak (~1 lb)</li>
                <li>Garlic, cilantro, onion, jalapeño, lime, orange</li>
                <li>Small corn tortillas, charro beans, salsa verde, queso fresco, soy sauce</li>
                <li>EVOO, cumin, chili powder, paprika, salt/pepper</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Season steak: pat dry, rub with oil, garlic, cumin, chili powder, paprika, salt, and pepper; rest 10 min. (If you have extra time, use the sous vide option in Step 2 instead.)</li>
                <li>Choose your cook method — Quick cast-iron: sear on a ripping-hot cast iron 3–4 min per side to 135°F, then rest 5 min and chop. Sous vide option (more time): bag steak with lime + orange juice, soy sauce, oil, garlic, cilantro, and dry spices; cook at 130°F for 1.5 hrs, pat dry, then sear cast iron 1–2 min per side for crust; rest 5 min and chop.</li>
                <li>Warm tortillas; top with steak, onion, jalapeño, cilantro, salsa verde, and queso fresco. Serve with charro beans.</li>
              </ol>
            </div>
          </div>
        </article>

      </div><!-- .dp-grid -->
    </section>

    <!-- ═══════════════════════════════════════════ WEEK 2 ══ -->
    <section class="dp-week" id="week2">
      <h2 class="dp-week-title">Week 2</h2>

      <div class="dp-grid">

        <!-- MON -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Monday</span>
            <h3 class="dp-meal">Spicy Tuna "Sushi" Bowl</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~15–20 min</span>
            <span class="dp-stat"><em>Cal</em> 480 kcal</span>
            <span class="dp-stat"><em>Macros</em> 40P · 45C · 12F</span>
            <span class="dp-stat"><em>Cost</em> $5–$7</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>Canned or sushi-grade tuna</li>
                <li>Avocado, cucumber, edamame, green onion (opt)</li>
                <li>Sushi rice or jasmine rice, soy sauce, rice vinegar, nori (opt), pickled ginger (opt)</li>
                <li>Sriracha mayo (mayo + sriracha), sesame oil, sesame seeds, pinch of salt</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Cook rice; season while warm with rice vinegar and a pinch of salt.</li>
                <li>Mix tuna with sriracha mayo, soy sauce, and sesame oil to taste.</li>
                <li>Slice avocado + cucumber. Thaw edamame if frozen.</li>
                <li>Build bowls: rice base, spicy tuna, avocado, cucumber, and edamame. Top with sesame seeds, green onion, nori, and pickled ginger as desired.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- TUE -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Tuesday</span>
            <h3 class="dp-meal">Salsa Verde Chicken Bowl</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> 20 min</span>
            <span class="dp-stat"><em>Cal</em> 500 kcal</span>
            <span class="dp-stat"><em>Macros</em> 40P · 55C · 15F</span>
            <span class="dp-stat"><em>Cost</em> $3–$5</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>1 lb chicken breast</li>
                <li>Avocado, cilantro, lime</li>
                <li>1 large jar salsa verde (green salsa), brown rice, canned black beans, sour cream (opt)</li>
                <li>Salt/pepper</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Add chicken + entire jar of salsa verde to InstantPot. Cook on high for 9 minutes.</li>
                <li>Shred chicken directly in pot; stir to coat with sauce.</li>
                <li>Cook brown rice in the InstantPot on high for 22 minutes using a 1:1.25 brown rice-to-chicken-stock ratio (e.g., 1 cup rice to 1¼ cups stock). Warm drained black beans in a small pot.</li>
                <li>Build bowl: rice &rarr; beans &rarr; chicken &rarr; avocado. Squeeze lime, top with cilantro.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- WED -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Wednesday</span>
            <h3 class="dp-meal">Beef Barley Stew</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~15–20 min</span>
            <span class="dp-stat"><em>Cal</em> 400 kcal</span>
            <span class="dp-stat"><em>Macros</em> 30P · 50C · 12F</span>
            <span class="dp-stat"><em>Cost</em> $4–$6</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>1.5 lbs beef stew meat, cubed</li>
                <li>Carrots, celery, onion, mushrooms, garlic</li>
                <li>Pearl barley (¾ cup), diced tomatoes (1 can), beef broth (4 cups), Worcestershire, tomato paste</li>
                <li>Thyme, rosemary, bay leaf, salt/pepper, EVOO</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Season and sear beef in EVOO until browned on all sides; set aside.</li>
                <li>Sauté onion, carrots, and celery 5 min. Add garlic + tomato paste 1 min.</li>
                <li>Return beef; add broth, tomatoes, barley, Worcestershire, and herbs. Bring to a boil.</li>
                <li>Simmer covered 45–55 min until barley is tender and beef is fork-soft. Remove bay leaf; adjust seasoning.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- THU -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Thursday</span>
            <h3 class="dp-meal">Deconstructed Burger Bowl</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~20 min</span>
            <span class="dp-stat"><em>Cal</em> 580 kcal</span>
            <span class="dp-stat"><em>Macros</em> 45P · 30C · 28F</span>
            <span class="dp-stat"><em>Cost</em> $5–$8</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>93/7 lean ground beef</li>
                <li>Romaine or shredded iceberg, cherry tomatoes, pickles, red onion</li>
                <li>Cheddar cheese, brioche croutons or toasted bun pieces (opt)</li>
                <li>Burger sauce: mayo, ketchup, mustard, relish, smoked paprika, garlic powder, salt/pepper</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Brown beef in a skillet over medium-high heat; season with salt, pepper, and garlic powder. Drain if needed.</li>
                <li>Mix burger sauce ingredients in a bowl; taste and adjust.</li>
                <li>Build bowls: lettuce base, beef, tomatoes, pickles, red onion, and cheese.</li>
                <li>Drizzle sauce over top. Add croutons or toasted bun pieces if using and serve immediately.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- FRI -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Friday</span>
            <h3 class="dp-meal">Sweet Potato Turkey Skillet</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~20 min</span>
            <span class="dp-stat"><em>Cal</em> 450 kcal</span>
            <span class="dp-stat"><em>Macros</em> 30P · 40C · 18F</span>
            <span class="dp-stat"><em>Cost</em> $3–$5</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>1 lb ground turkey (93/7)</li>
                <li>2 medium sweet potatoes, cubed small, bell pepper, onion, baby spinach, garlic</li>
                <li>Chicken broth (¼ cup)</li>
                <li>EVOO, smoked paprika, cumin, chili powder, salt/pepper, hot sauce (opt)</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Microwave cubed sweet potato 4–5 min to par-cook. Season turkey with spices.</li>
                <li>Brown turkey in skillet over medium-high heat 6–8 min, breaking apart; set aside.</li>
                <li>Sauté onion + bell pepper 3–4 min. Add garlic 30 sec. Add sweet potato + broth; cover 5 min until tender.</li>
                <li>Return turkey; fold in spinach until wilted. Adjust seasoning. Serve with hot sauce if desired.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- SAT -->
        <article class="dp-card">
          <div class="dp-card-head">
            <span class="dp-day">Saturday</span>
            <h3 class="dp-meal">Shrimp Fried Rice</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~20 min</span>
            <span class="dp-stat"><em>Cal</em> 450 kcal</span>
            <span class="dp-stat"><em>Macros</em> 30P · 50C · 12F</span>
            <span class="dp-stat"><em>Cost</em> $5–$7</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>1 lb shrimp, peeled &amp; deveined</li>
                <li>Broccoli, bell pepper, snap peas, carrots, garlic, ginger (fresh or paste), green onion</li>
                <li>1 cup cooked brown rice (day-old preferred), 3 eggs, soy sauce, oyster sauce (opt)</li>
                <li>Sesame oil</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Season shrimp with salt + pepper. Sauté in hot wok/skillet 1–2 min per side; set aside.</li>
                <li>Add garlic + ginger; stir 30 sec. Add vegetables; cook 4–5 min until tender-crisp.</li>
                <li>Push veggies aside; scramble eggs in the pan. Combine everything.</li>
                <li>Add rice; stir-fry 2–3 min. Add shrimp back. Season with soy sauce + sesame oil. Top with green onion.</li>
              </ol>
            </div>
          </div>
        </article>

        <!-- SUN -->
        <article class="dp-card dp-card--full">
          <div class="dp-card-head">
            <span class="dp-day">Sunday</span>
            <h3 class="dp-meal">Skillet French Onion Chicken + Mushrooms</h3>
          </div>
          <div class="dp-stats-row">
            <span class="dp-stat"><em>Prep</em> ~30–35 min</span>
            <span class="dp-stat"><em>Cal</em> 520 kcal</span>
            <span class="dp-stat"><em>Macros</em> 45P · 20C · 28F</span>
            <span class="dp-stat"><em>Cost</em> $6–$9</span>
          </div>
          <div class="dp-body">
            <div class="dp-col">
              <div class="dp-col-label">Ingredients</div>
              <ul>
                <li>Chicken thighs or breasts</li>
                <li>Yellow onions (2 large), mushrooms (cremini or baby bella), garlic</li>
                <li>Gruy&egrave;re or Swiss cheese, beef or chicken broth</li>
                <li>Butter, EVOO, thyme, Worcestershire, salt/pepper</li>
              </ul>
            </div>
            <div class="dp-col">
              <div class="dp-col-label">Steps</div>
              <ol>
                <li>Season and sear chicken in EVOO for 3–4 min per side; remove from skillet.</li>
                <li>Caramelize onions in butter over low/medium heat for 20–25 min. Add garlic + thyme and cook 1 min.</li>
                <li>Add mushrooms and cook 4–5 min. Deglaze with broth and Worcestershire.</li>
                <li>Nestle chicken in skillet and simmer 8–10 min until cooked through. Top with cheese and broil 2 min.</li>
              </ol>
            </div>
          </div>
        </article>

      </div><!-- .dp-grid -->
    </section>

    <!-- ══════════════════════════════════════ LUNCH OPTIONS ══ -->
    <section class="dp-week" id="lunch">
      <h2 class="dp-week-title">Lunch Options</h2>

      <div class="dp-lunch-grid">
        <div class="dp-lunch-card">
          <div class="dp-lunch-title">Go-To Picks</div>
          <ul>
            <li>Fruit (apple / berries / citrus / kiwi)</li>
            <li>Veg + hummus</li>
            <li>Kimchi, kefir</li>
            <li>Prepared salads (orzo / kale)</li>
            <li>Nuggets / wings / dumplings</li>
            <li>Avocado turkey sandwich</li>
          </ul>
        </div>

        <div class="dp-lunch-card">
          <div class="dp-lunch-title">Grab &amp; Go</div>
          <ul>
            <li>Turkey slices, summer sausage, turkey sticks</li>
            <li>Tuna + crackers</li>
            <li>Pumpkin seeds, pistachios, trail mix</li>
            <li>IQBar, Alyssa's bites</li>
            <li>Poshi olives</li>
          </ul>
        </div>

        <div class="dp-lunch-card">
