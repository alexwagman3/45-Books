              <span class="fyb-stat-chip-value">550 kcal</span>
            </div>
            <div class="fyb-stat-chip">
              <span class="fyb-stat-chip-label">Macros</span>
              <span class="fyb-stat-chip-value">40g P · 35g C · 25g F</span>
            </div>
            <div class="fyb-stat-chip">
              <span class="fyb-stat-chip-label">Cost / serving</span>
              <span class="fyb-stat-chip-value">$4–$6</span>
