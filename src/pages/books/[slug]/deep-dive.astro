---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books
    .filter((b) => b.data.hasDeepDive)
    .map((book) => ({
      params: { slug: book.slug },
      props: { book },
    }));
}

type Props = { book: CollectionEntry<'books'> };
const { book } = Astro.props;
---

<BaseLayout
  title={`${book.data.title} — Deep Dive`}
  description={`Deep dive into ${book.data.title} by ${book.data.author}`}
>
  <a class="overlay-back" href={`/books/${book.slug}/takeaways/`}>&#8592; Back to Takeaways</a>
  <a class="overlay-close" href="/" aria-label="Close">&times;</a>

  <div class="takeaways-content">
    <span class="takeaways-tag">{book.data.shelfLabel}</span>
    <h1 class="takeaways-title">{book.data.title} — Deep Dive</h1>
    <p class="takeaways-author">By {book.data.author}</p>

    <div class="overlay-coming-soon">
      Deep dive content is being migrated. Check back soon.
    </div>
  </div>
</BaseLayout>
