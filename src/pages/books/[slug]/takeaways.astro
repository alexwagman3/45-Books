---
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books
    .filter((b) => b.data.hasTakeaways)
    .map((book) => ({
      params: { slug: book.slug },
      props: { book },
    }));
}

type Props = { book: CollectionEntry<'books'> };
const { book } = Astro.props;

// ─── Shelf-level shared takeaway pages ───────────────────────────────────────
// These three shelves combine takeaways across all three books in the shelf.
// Books in each shelf redirect to their shared page via immediate JS redirect.

const LOVE_NEIGHBORS_SLUGS = new Set([
  'how-to-win-friends-and-influence-people',
  'find-your-people',
  'the-art-of-neighboring',
]);

const DISCIPLE_SLUGS = new Set([
  'master-plan-of-evangelism',
  'evidence-for-jesus',
  'instruments-in-the-redeemers-hands',
]);

const FEED_YOUR_BODY_SLUGS = new Set([
  'how-to-cook-everything',
  'everything-fat-loss',
  'the-whole-foods-diet',
]);

const WORSHIP_SLUGS = new Set([
  'called-to-worship',
  'sacred-pathways',
  'the-battle-plan-for-prayer',
]);

const LOVE_YOUR_FAMILY_SLUGS = new Set([
  'good-inside',
  'cribsheet',
  'the-5-love-languages-of-teenagers',
]);

const redirectTo =
  LOVE_NEIGHBORS_SLUGS.has(book.slug)     ? '/love-your-neighbors/takeaways/' :
  DISCIPLE_SLUGS.has(book.slug)           ? '/disciple/takeaways/' :
  FEED_YOUR_BODY_SLUGS.has(book.slug)     ? '/feed-your-body/takeaways/' :
  WORSHIP_SLUGS.has(book.slug)            ? '/worship/takeaways/' :
  LOVE_YOUR_FAMILY_SLUGS.has(book.slug)   ? '/love-your-family/takeaways/' :
  null;

// ─── Individual book takeaways ────────────────────────────────────────────────
const notesEntry = !redirectTo ? await getEntry('personal-takeaways', book.slug) : null;
const hasNotes = !!notesEntry;
const { Content: NotesContent } = hasNotes
  ? await notesEntry!.render()
  : { Content: null };
---

<BaseLayout
  title={`${book.data.title} — Takeaways`}
  description={`Personal takeaways from ${book.data.title} by ${book.data.author}`}
>
  {redirectTo && (
    <!-- Immediate JS redirect — runs before paint, no flash -->
    <script is:inline define:vars={{ redirectTo }}>window.location.replace(redirectTo);</script>
  )}

  <a class="overlay-back" href={`/books/${book.slug}/`}>&#8592; Back to Book</a>
  <a class="overlay-close" href="/" aria-label="Close">&times;</a>

  <div class="takeaways-content">
    <span class="takeaways-tag">{book.data.shelfLabel}</span>
    <h1 class="takeaways-title">{book.data.title}</h1>
    <p class="takeaways-author">By {book.data.author}</p>

    {!redirectTo && !hasNotes && (
      <div class="overlay-coming-soon">
        Personal takeaways haven't been added for this book yet. Check back soon.
      </div>
    )}

    {hasNotes && (
      <>
        <!-- TABLE OF CONTENTS (populated by script below) -->
        <div class="book-chapter-heading" id="bookChapterHeading" style="display:none">
          <span>Table of Contents</span>
        </div>
        <div class="book-chapter-nav" id="bookChapterNav" style="display:none" role="navigation" aria-label="Chapter navigation"></div>

        <div class="excerpts-section" id="notesSection">
          <div class="overlay-summary-label excerpts-label">
            Direct Quotes &amp; Excerpts From The Book
          </div>
          <div class="takeaways-body" id="overlayFullBody">
            <NotesContent />
          </div>
        </div>
      </>
    )}
  </div>
</BaseLayout>

<script>
  /**
   * Rebuild the TABLE OF CONTENTS nav from h1/h2 headings in the notes body.
   * Strips the leading book-title h1, author paragraph, and hr divider that
   * appear at the top of every takeaways/*.md file.
   */
  (function () {
    const navEl     = document.getElementById('bookChapterNav') as HTMLElement | null;
    const headingEl = document.getElementById('bookChapterHeading') as HTMLElement | null;
    const bodyEl    = document.getElementById('overlayFullBody') as HTMLElement | null;
    if (!navEl || !headingEl || !bodyEl) return;

    // Strip the leading book-title h1, author bold-paragraph, and divider hr
    const firstEl = bodyEl.firstElementChild;
    if (firstEl && firstEl.tagName === 'H1') {
      let next = firstEl.nextElementSibling;
      firstEl.remove();
      if (next && next.tagName === 'P' && next.querySelector('strong') && next.children.length === 1) {
        const authorEl = next;
        next = authorEl.nextElementSibling;
        authorEl.remove();
      }
      if (next && next.tagName === 'HR') {
        next.remove();
      }
    }

    interface NavEntry { el: HTMLElement; isSection: boolean; label: string }
    const entries: NavEntry[] = [];

    bodyEl.querySelectorAll<HTMLElement>('h1, h2').forEach((h, i) => {
      if (!h.id) h.id = 'note-section-' + i;
      entries.push({ el: h, isSection: h.tagName === 'H1', label: h.textContent?.trim() || '' });
    });

    if (entries.length === 0) return;

    entries.forEach(({ el, isSection, label }) => {
      const btn = document.createElement('button');
      btn.className = 'book-chapter-nav-item' + (isSection ? ' is-section' : '');
      btn.textContent = label;
      btn.addEventListener('click', () => {
        el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      navEl.appendChild(btn);
    });

    headingEl.style.display = 'flex';
    navEl.style.display     = 'flex';
  })();
</script>
