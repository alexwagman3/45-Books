---
import { readFileSync } from 'node:fs';
import { join }         from 'node:path';
import BaseLayout       from '../../layouts/BaseLayout.astro';

// Strip UTF-8 BOM if present
const raw = readFileSync(join(process.cwd(), 'src/data/texts-content.txt'), 'utf-8').replace(/^\uFEFF/, '');

/* ── Utilities ──────────────────────────────────────────────── */
function esc(s: string): string {
  return String(s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

function slugify(s: string): string {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

/* ── Parse file into top-level sections ─────────────────────── */
interface Section {
  title: string;
  id: string;
  content: string;
}

function parseSections(text: string): Section[] {
  const sections: Section[] = [];
  // Top-level section header: starts at col 0 with a letter (not "- "), ends with ":"
  const lines = text.split('\n');
  let currentTitle: string | null = null;
  let currentStart = 0;

  for (let i = 0; i < lines.length; i++) {
    const line = lines[i];
    // Match top-level header: no leading whitespace, no leading "- ", ends with ":"
    if (/^[A-Za-z].*:\s*$/.test(line) && !/^- /.test(line)) {
      if (currentTitle !== null) {
        const content = lines.slice(currentStart, i).join('\n').trim();
        sections.push({ title: currentTitle, id: 'section-' + slugify(currentTitle), content });
      }
      currentTitle = line.replace(/:\s*$/, '').trim();
      currentStart = i + 1;
    }
  }
  // Last section
  if (currentTitle !== null) {
    const content = lines.slice(currentStart).join('\n').trim();
    sections.push({ title: currentTitle, id: 'section-' + slugify(currentTitle), content });
  }
  return sections;
}

/* ── Render section content to HTML ─────────────────────────── */
function renderContent(content: string): string {
  const lines = content.split('\n');

  // Detect sub-category blocks: lines like "- SubCat:" at col 0
  const subCatLines = lines.filter(l => /^- [A-Z].*:\s*$/.test(l));
  if (subCatLines.length >= 2) {
    return renderSubCategories(lines);
  }

  const html: string[] = [];
  // Split into blocks by 2+ blank lines
  const blocks = content.split(/\n{2,}/);

  for (const block of blocks) {
    const trimmed = block.trim();
    if (!trimmed) continue;

    const blockLines = trimmed.split('\n');

    // Sub-header: single non-blank line ending with ":", short enough to be a label
    const firstTrimmed = blockLines[0].trim();
    if (
      blockLines.filter(l => l.trim()).length === 1 &&
      /^[A-Za-z].*:\s*$/.test(firstTrimmed) &&
      firstTrimmed.length < 70
    ) {
      html.push(`<div class="texts-subheader">${esc(firstTrimmed.replace(/:\s*$/, ''))}</div>`);
      continue;
    }

    // Block starts with a sub-header (first line ends with ":", remaining has content)
    if (
      /^[A-Za-z].*:\s*$/.test(firstTrimmed) &&
      firstTrimmed.length < 70 &&
      blockLines.length > 1
    ) {
      html.push(`<div class="texts-subheader">${esc(firstTrimmed.replace(/:\s*$/, ''))}</div>`);
      const rest = blockLines.slice(1).join('\n').trim();
      if (rest) html.push(renderContent(rest));
      continue;
    }

    // Bullet list block
    const bulletLines = blockLines.filter(l => /^\s*- /.test(l));
    const nonEmptyLines = blockLines.filter(l => l.trim());
    if (bulletLines.length > 0 && bulletLines.length >= nonEmptyLines.length * 0.5) {
      const firstBulletIdx = blockLines.findIndex(l => /^\s*- /.test(l));
      if (firstBulletIdx > 0) {
        const intro = blockLines.slice(0, firstBulletIdx).join('\n').trim();
        if (intro) {
          html.push(`<div class="dd-item texts-message">${esc(intro).replace(/\n/g, '<br>')}</div>`);
        }
      }
      const bullets = bulletLines.map(l => l.replace(/^\s*- /, '').trim());
      const lis = bullets.map(b => `<li>${esc(b)}</li>`).join('');
      html.push(`<ul class="texts-bullet-list">${lis}</ul>`);

      const lastBulletIdx = blockLines.reduce((max, l, i) => /^\s*- /.test(l) ? i : max, -1);
      if (lastBulletIdx >= 0 && lastBulletIdx < blockLines.length - 1) {
        const outro = blockLines.slice(lastBulletIdx + 1).join('\n').trim();
        if (outro) {
          html.push(`<div class="dd-item texts-message">${esc(outro).replace(/\n/g, '<br>')}</div>`);
        }
      }
      continue;
    }

    // Numbered list block
    if (blockLines.some(l => /^\s*\d+\. /.test(l))) {
      const firstNumIdx = blockLines.findIndex(l => /^\s*\d+\. /.test(l));
      if (firstNumIdx > 0) {
        const intro = blockLines.slice(0, firstNumIdx).join('\n').trim();
        if (intro) {
          html.push(`<div class="dd-item texts-message">${esc(intro).replace(/\n/g, '<br>')}</div>`);
        }
      }
      const numItems = blockLines.filter(l => /^\s*\d+\. /.test(l)).map(l => l.replace(/^\s*\d+\. /, '').trim());
      const lis = numItems.map(i => `<li>${esc(i)}</li>`).join('');
      html.push(`<ol class="texts-numbered-list">${lis}</ol>`);

      const lastNumIdx = blockLines.reduce((max, l, i) => /^\s*\d+\. /.test(l) ? i : max, -1);
      if (lastNumIdx >= 0 && lastNumIdx < blockLines.length - 1) {
        const outro = blockLines.slice(lastNumIdx + 1).join('\n').trim();
        if (outro) {
          html.push(`<div class="dd-item texts-message">${esc(outro).replace(/\n/g, '<br>')}</div>`);
        }
      }
      continue;
    }

    // URL-only block
    if (nonEmptyLines.every(l => /^https?:\/\//.test(l.trim()))) {
      const urls = nonEmptyLines.map(l => l.trim());
      const links = urls.map(u => `<a href="${esc(u)}" class="texts-url" target="_blank" rel="noopener">${esc(u)}</a>`).join('');
      html.push(`<div class="texts-urls">${links}</div>`);
      continue;
    }

    // Regular message
    html.push(`<div class="dd-item texts-message">${esc(trimmed).replace(/\n/g, '<br>')}</div>`);
  }

  return html.join('');
}

/* ── Render "Follow-Up" style sub-category blocks ───────────── */
function renderSubCategories(lines: string[]): string {
  const html: string[] = [];
  let subCatTitle: string | null = null;
  let subItems: string[] = [];

  const flushSubCat = () => {
    if (subCatTitle !== null) {
      const itemsHtml = subItems
        .map(t => `<div class="dd-item texts-message">${esc(t).replace(/\n/g, '<br>')}</div>`)
        .join('');
      html.push(`<div class="texts-subcategory">
        <div class="texts-subcategory-title">${esc(subCatTitle)}</div>
        ${itemsHtml}
      </div>`);
    }
  };

  let currentItem: string[] = [];

  const flushItem = () => {
    const t = currentItem.join('\n').trim();
    if (t) subItems.push(t);
    currentItem = [];
  };

  for (const line of lines) {
    const lineTrimmed = line.trim();

    // Sub-category header: "- SubCat:" at col 0
    if (/^- [A-Za-z].*:\s*$/.test(line)) {
      flushItem();
      flushSubCat();
      subCatTitle = line.replace(/^- /, '').replace(/:\s*$/, '').trim();
      subItems = [];
      continue;
    }

    if (!lineTrimmed) {
      flushItem();
      continue;
    }

    // Item within sub-category
    if (subCatTitle !== null) {
      const t = line.replace(/^\s+- /, '').trimStart();
      currentItem.push(t);
    }
  }

  flushItem();
  flushSubCat();
  return html.join('');
}

/* ── Section icons ───────────────────────────────────────────── */
const ICONS: Record<string, string> = {
  'Birthdays': '&#127874;',
  "Birthday Thank-You's": '&#128591;',
  'Just Announced Pregnancy': '&#128116;',
  'Newborn Baby': '&#128118;',
  'Professional/Work': '&#128188;',
  'College': '&#127891;',
  'For My Wedding': '&#128141;',
  "For Someone Else's Wedding": '&#127867;',
  'Anniversary Wishes': '&#128145;',
  'Baby Shower Thank-Yous': '&#127873;',
  'Random Compliment': '&#11088;',
  'Mourning/Loss': '&#128153;',
  'Follow Up Check-In Texts for Tough Stressful Situations': '&#129309;',
  'Well Wishes': '&#128140;',
  "Simple Thank You's": '&#128591;',
  "Veteran's Day": '&#127988;',
};

/* ── Build HTML ──────────────────────────────────────────────── */
const sections = parseSections(raw);

const navHtml = `<div class="texts-nav-wrapper" id="texts-top">
  <div class="texts-nav-label">Jump to a Section</div>
  <div class="texts-nav-grid">
    ${sections.map(s => {
      const icon = ICONS[s.title] ?? '';
      return `<a href="#${s.id}" class="texts-nav-btn">${icon ? `<span class="texts-nav-icon">${icon}</span>` : ''}<span>${esc(s.title)}</span></a>`;
    }).join('')}
  </div>
</div>`;

const sectionsHtml = sections.map(s => {
  const contentHtml = renderContent(s.content);
  return `<div class="texts-section" id="${s.id}">
    <div class="texts-section-header">
      <span class="texts-section-icon">${ICONS[s.title] ?? ''}</span>
      <div class="dd-category-title texts-section-title">${esc(s.title)}</div>
      <a href="#texts-top" class="texts-top-link" aria-label="Back to top">&#8593; Top</a>
    </div>
    <div class="texts-section-body">${contentHtml}</div>
  </div>`;
}).join('');

const pageHtml = navHtml + sectionsHtml;
---

<BaseLayout
  title="Love Your Neighbors — Showing Up with Words"
  description="Real message templates for every life event: loss, celebration, hard news, encouragement, and everyday check-ins."
  canonicalPath="/love-your-neighbors/takeaways-texts/"
>
  <a class="overlay-back" href="/love-your-neighbors/takeaways/">&#8592; Back to Takeaways</a>
  <a class="overlay-close" href="/" aria-label="Close">&times;</a>

  <div class="takeaways-content">
    <span class="takeaways-tag">Love Your Neighbors</span>
    <h1 class="takeaways-title">The Art of Showing Up with Words</h1>
    <p class="texts-subtitle">Real messages for every major life event — blueprints for your own voice</p>
    <div class="texts-count-bar">
      <span class="texts-count-item">&#127874; Birthdays</span>
      <span class="texts-count-divider">&middot;</span>
      <span class="texts-count-item">&#128591; Thank-Yous</span>
      <span class="texts-count-divider">&middot;</span>
      <span class="texts-count-item">&#128153; Grief &amp; Loss</span>
      <span class="texts-count-divider">&middot;</span>
      <span class="texts-count-item">&#129309; Check-Ins</span>
      <span class="texts-count-divider">&middot;</span>
      <span class="texts-count-item">&#128140; Well Wishes</span>
    </div>

    <Fragment set:html={pageHtml} />
  </div>

  <div class="dd-page-nav">
    <a class="dd-nav-btn dd-nav-prev" href="/love-your-neighbors/takeaways-compliments/">&#8592; Compliment Library</a>
    <a class="dd-nav-btn dd-nav-next" href="/love-your-neighbors/takeaways-questions/">Asking Good Questions &#8594;</a>
  </div>
</BaseLayout>

<style>
/* ── Page subtitle ───────────────────────────────────────────── */
.texts-subtitle {
  font-size: 1rem;
  color: #7a7368;
  font-style: italic;
  margin-bottom: 2.75rem;
  font-family: 'EB Garamond', serif;
  line-height: 1.6;
}

/* ── Category summary bar ────────────────────────────────────── */
.texts-count-bar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.5rem 0.6rem;
  margin-bottom: 2.5rem;
  padding: 0.8rem 1.1rem;
  background: rgba(255, 255, 255, 0.35);
  border: 1px solid rgba(199, 187, 170, 0.35);
  border-radius: 8px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  color: #7a7368;
}

.texts-count-item {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  white-space: nowrap;
}

.texts-count-divider {
  color: rgba(183, 156, 92, 0.45);
  font-size: 0.9rem;
}

/* ── Navigation wrapper ──────────────────────────────────────── */
.texts-nav-wrapper {
  margin-bottom: 3.5rem;
  padding: 1.75rem 2rem;
  background: linear-gradient(135deg, rgba(183, 156, 92, 0.06), rgba(199, 187, 170, 0.08));
  border: 1px solid rgba(183, 156, 92, 0.22);
  border-radius: 12px;
}

.texts-nav-label {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: #b79c5c;
  margin-bottom: 1.25rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.texts-nav-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(183, 156, 92, 0.2);
}

.texts-nav-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(175px, 1fr));
  gap: 0.5rem;
}

.texts-nav-btn {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.6rem 0.9rem;
  background: rgba(255, 255, 255, 0.55);
  border: 1px solid rgba(199, 187, 170, 0.5);
  border-radius: 8px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.72rem;
  font-weight: 500;
  color: #5c5449;
  text-decoration: none;
  transition: background 0.18s, color 0.18s, border-color 0.18s, transform 0.15s;
  line-height: 1.35;
}

.texts-nav-btn:hover {
  background: #6a6156;
  color: #f3efe9;
  border-color: #6a6156;
  transform: translateY(-1px);
}

.texts-nav-icon {
  font-size: 1.05rem;
  line-height: 1;
  flex-shrink: 0;
}

/* ── Section container ───────────────────────────────────────── */
.texts-section {
  margin-bottom: 4rem;
  scroll-margin-top: 1.5rem;
}

.texts-section-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1.75rem;
  padding: 1rem 1.25rem;
  background: linear-gradient(135deg, rgba(183, 156, 92, 0.08), rgba(199, 187, 170, 0.06));
  border: 1px solid rgba(183, 156, 92, 0.18);
  border-left: 4px solid rgba(183, 156, 92, 0.55);
  border-radius: 0 8px 8px 0;
}

.texts-section-icon {
  font-size: 1.4rem;
  line-height: 1;
  flex-shrink: 0;
}

.texts-section-title {
  margin: 0;
  padding: 0;
  border: none;
  flex: 1;
  font-size: 1.15rem;
  letter-spacing: 0.01em;
}

.texts-top-link {
  flex-shrink: 0;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.62rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  color: #b79c5c;
  text-decoration: none;
  padding: 0.3rem 0.7rem;
  border: 1px solid rgba(183, 156, 92, 0.3);
  border-radius: 4px;
  opacity: 0.75;
  transition: opacity 0.2s, background 0.2s;
}

.texts-top-link:hover {
  opacity: 1;
  background: rgba(183, 156, 92, 0.1);
}

/* ── Message cards ───────────────────────────────────────────── */
.texts-message {
  padding: 1.1rem 1.4rem;
  background: rgba(255, 255, 255, 0.52);
  border: 1px solid rgba(199, 187, 170, 0.4);
  border-radius: 8px;
  margin-bottom: 0.75rem;
  font-family: 'EB Garamond', serif;
  font-size: 1rem;
  color: #4f4742;
  line-height: 1.82;
  max-width: 82ch;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  transition: box-shadow 0.2s, border-color 0.2s;
  position: relative;
}

.texts-message:hover {
  box-shadow: 0 3px 12px rgba(0, 0, 0, 0.07);
  border-color: rgba(183, 156, 92, 0.35);
}

/* ── Sub-header labels (within sections) ─────────────────────── */
.texts-subheader {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #b79c5c;
  margin-top: 2.25rem;
  margin-bottom: 0.9rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.texts-subheader::before {
  content: '';
  width: 18px;
  height: 2px;
  background: rgba(183, 156, 92, 0.5);
  border-radius: 1px;
  flex-shrink: 0;
}

.texts-subheader::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(183, 156, 92, 0.15);
}

/* ── Bullet list ─────────────────────────────────────────────── */
.texts-bullet-list {
  list-style: none;
  padding: 0;
  margin: 0 0 0.75rem;
  max-width: 82ch;
  background: rgba(255, 255, 255, 0.38);
  border: 1px solid rgba(199, 187, 170, 0.3);
  border-radius: 8px;
  overflow: hidden;
}

.texts-bullet-list li {
  font-family: 'EB Garamond', serif;
  font-size: 1rem;
  color: #4f4742;
  line-height: 1.75;
  padding: 0.65rem 1.2rem 0.65rem 2rem;
  position: relative;
  border-bottom: 1px solid rgba(199, 187, 170, 0.18);
  transition: background 0.15s;
}

.texts-bullet-list li:last-child {
  border-bottom: none;
}

.texts-bullet-list li:hover {
  background: rgba(183, 156, 92, 0.04);
}

.texts-bullet-list li::before {
  content: '\2014';
  position: absolute;
  left: 0.75rem;
  color: #b79c5c;
  opacity: 0.7;
}

/* ── Numbered list ───────────────────────────────────────────── */
.texts-numbered-list {
  padding-left: 1.75rem;
  margin: 0 0 0.75rem;
  max-width: 82ch;
}

.texts-numbered-list li {
  font-family: 'EB Garamond', serif;
  font-size: 1rem;
  color: #4f4742;
  line-height: 1.8;
  margin-bottom: 0.5rem;
  padding-left: 0.3rem;
}

.texts-numbered-list li::marker {
  color: #b79c5c;
  font-weight: 600;
}

/* ── Sub-categories (Follow-Up section) ─────────────────────── */
.texts-subcategory {
  margin-bottom: 2rem;
  padding: 1rem 1.25rem;
  background: rgba(255, 255, 255, 0.35);
  border: 1px solid rgba(199, 187, 170, 0.3);
  border-left: 3px solid rgba(183, 156, 92, 0.45);
  border-radius: 0 8px 8px 0;
}

.texts-subcategory-title {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #b79c5c;
  margin-bottom: 0.9rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid rgba(183, 156, 92, 0.15);
}

/* ── URL lists ───────────────────────────────────────────────── */
.texts-urls {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  margin-bottom: 0.75rem;
}

.texts-url {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  color: #b79c5c;
  text-decoration: underline;
  word-break: break-all;
  opacity: 0.8;
  transition: opacity 0.2s;
}

.texts-url:hover {
  opacity: 1;
}

/* ── Section body spacing ────────────────────────────────────── */
.texts-section-body {
  padding-left: 0.25rem;
}

/* ── Responsive ──────────────────────────────────────────────── */
@media (max-width: 680px) {
  .texts-nav-grid {
    grid-template-columns: repeat(auto-fill, minmax(145px, 1fr));
  }

  .texts-nav-wrapper {
    padding: 1.25rem 1.1rem;
  }
}

@media (max-width: 520px) {
  .texts-count-bar {
    display: none;
  }

  .texts-nav-wrapper {
    padding: 1.1rem 1rem;
  }

  .texts-nav-grid {
    grid-template-columns: 1fr 1fr;
  }

  .texts-nav-btn {
    font-size: 0.68rem;
    padding: 0.55rem 0.75rem;
  }

  .texts-section-header {
    padding: 0.85rem 1rem;
  }

  .texts-message {
    padding: 0.9rem 1.1rem;
    font-size: 0.96rem;
  }

  .texts-bullet-list li {
    font-size: 0.96rem;
  }
}
</style>
