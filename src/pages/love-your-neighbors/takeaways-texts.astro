---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { raw, parseSections, renderContent, esc, ICONS } from '../../lib/texts-utils';

const PREVIEW_LIMIT = 5;
const sections = parseSections(raw);

const navHtml = `<div class="texts-nav-wrapper" id="texts-top">
  <div class="texts-nav-label">Jump to a Section</div>
  <div class="texts-nav-grid">
    ${sections.map(s => {
      const icon = ICONS[s.title] ?? '';
      return `<a href="#${s.id}" class="texts-nav-btn">${icon ? `<span class="texts-nav-icon">${icon}</span>` : ''}<span>${esc(s.title)}</span></a>`;
    }).join('')}
  </div>
</div>`;

const sectionsHtml = sections.map(s => {
  const { html: contentHtml, hasMore } = renderContent(s.content, PREVIEW_LIMIT);
  const moreBtn = hasMore
    ? `<a href="/love-your-neighbors/takeaways-texts/${s.slug}/" class="texts-more-btn">
        See all messages &rarr;
       </a>`
    : '';
  return `<div class="texts-section" id="${s.id}">
    <div class="texts-section-header">
      <span class="texts-section-icon">${ICONS[s.title] ?? ''}</span>
      <div class="dd-category-title texts-section-title">${esc(s.title)}</div>
      <a href="#texts-top" class="texts-top-link" aria-label="Back to top">&#8593; Top</a>
    </div>
    <div class="texts-section-body">${contentHtml}</div>
    ${moreBtn}
  </div>`;
}).join('');

const pageHtml = navHtml + sectionsHtml;
---

<BaseLayout
  title="Love Your Neighbors — Showing Up with Words"
  description="Real message templates for every life event: loss, celebration, hard news, encouragement, and everyday check-ins."
  canonicalPath="/love-your-neighbors/takeaways-texts/"
>
  <a class="overlay-back" href="/love-your-neighbors/takeaways/">&#8592; Back to Takeaways</a>
  <a class="overlay-close" href="/" aria-label="Close">&times;</a>

  <div class="takeaways-content">
    <span class="takeaways-tag">Love Your Neighbors</span>
    <h1 class="takeaways-title">The Art of Showing Up with Words</h1>
    <p class="texts-subtitle">Real messages for every major life event — blueprints for your own voice</p>

    <Fragment set:html={pageHtml} />
  </div>

  <div class="dd-page-nav">
    <a class="dd-nav-btn dd-nav-prev" href="/love-your-neighbors/takeaways-compliments/">&#8592; Compliment Library</a>
    <a class="dd-nav-btn dd-nav-next" href="/love-your-neighbors/takeaways-questions/">Asking Good Questions &#8594;</a>
  </div>
</BaseLayout>

<style>
/* ── Page subtitle ───────────────────────────────────────────── */
.texts-subtitle {
  font-size: 1rem;
  color: #7a7368;
  font-style: italic;
  margin-bottom: 2.75rem;
  font-family: 'EB Garamond', serif;
  line-height: 1.6;
}


/* ── Navigation wrapper ──────────────────────────────────────── */
.texts-nav-wrapper {
  margin-bottom: 3.5rem;
  padding: 1.75rem 2rem;
  background: linear-gradient(135deg, rgba(183, 156, 92, 0.06), rgba(199, 187, 170, 0.08));
  border: 1px solid rgba(183, 156, 92, 0.22);
  border-radius: 12px;
}

.texts-nav-label {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #b79c5c;
  margin-bottom: 1.25rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.texts-nav-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(183, 156, 92, 0.2);
}

.texts-nav-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(175px, 1fr));
  gap: 0.5rem;
}

.texts-nav-btn {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.65rem 1rem;
  background: #f5f1eb;
  border: 1px solid #c7bbaa;
  border-radius: 8px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 500;
  color: #4f4742;
  text-decoration: none;
  transition: background 0.18s, color 0.18s, border-color 0.18s, transform 0.15s;
  line-height: 1.35;
}

.texts-nav-btn:hover {
  background: #6a6156;
  color: #f3efe9;
  border-color: #6a6156;
  transform: translateY(-1px);
}

.texts-nav-icon {
  font-size: 1.05rem;
  line-height: 1;
  flex-shrink: 0;
}

/* ── Section container ───────────────────────────────────────── */
.texts-section {
  margin-bottom: 4rem;
  scroll-margin-top: 1.5rem;
}

.texts-section-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1.75rem;
  padding: 1rem 1.25rem;
  background: linear-gradient(135deg, rgba(183, 156, 92, 0.08), rgba(199, 187, 170, 0.06));
  border: 1px solid rgba(183, 156, 92, 0.25);
  border-radius: 8px;
}

.texts-section-icon {
  font-size: 1.4rem;
  line-height: 1;
  flex-shrink: 0;
}

.texts-section-title {
  margin: 0;
  padding: 0;
  border: none;
  flex: 1;
  font-size: 1.15rem;
  letter-spacing: 0.01em;
}

.texts-top-link {
  flex-shrink: 0;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.62rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  color: #b79c5c;
  text-decoration: none;
  padding: 0.3rem 0.7rem;
  border: 1px solid rgba(183, 156, 92, 0.3);
  border-radius: 4px;
  opacity: 0.75;
  transition: opacity 0.2s, background 0.2s;
}

.texts-top-link:hover {
  opacity: 1;
  background: rgba(183, 156, 92, 0.1);
}

/* ── Message cards ───────────────────────────────────────────── */
.texts-message {
  padding: 1.1rem 1.4rem;
  background: rgba(255, 255, 255, 0.82);
  border: 1px solid rgba(199, 187, 170, 0.65);
  border-radius: 8px;
  margin-bottom: 0.75rem;
  font-family: 'EB Garamond', serif;
  font-size: 1rem;
  color: #4f4742;
  line-height: 1.82;
  max-width: 82ch;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  transition: box-shadow 0.2s, border-color 0.2s;
  position: relative;
}

.texts-message:hover {
  box-shadow: 0 3px 12px rgba(0, 0, 0, 0.07);
  border-color: rgba(183, 156, 92, 0.35);
}

/* ── Sub-header labels (within sections) ─────────────────────── */
.texts-subheader {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #b79c5c;
  margin-top: 2.25rem;
  margin-bottom: 0.9rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.texts-subheader::before {
  content: '';
  width: 18px;
  height: 2px;
  background: rgba(183, 156, 92, 0.5);
  border-radius: 1px;
  flex-shrink: 0;
}

.texts-subheader::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(183, 156, 92, 0.15);
}

/* ── Bullet list ─────────────────────────────────────────────── */
.texts-bullet-list {
  list-style: none;
  padding: 0;
  margin: 0 0 0.75rem;
  max-width: 82ch;
  background: rgba(255, 255, 255, 0.38);
  border: 1px solid rgba(199, 187, 170, 0.3);
  border-radius: 8px;
  overflow: hidden;
}

.texts-bullet-list li {
  font-family: 'EB Garamond', serif;
  font-size: 1rem;
  color: #4f4742;
  line-height: 1.75;
  padding: 0.65rem 1.2rem 0.65rem 2rem;
  position: relative;
  border-bottom: 1px solid rgba(199, 187, 170, 0.18);
  transition: background 0.15s;
}

.texts-bullet-list li:last-child {
  border-bottom: none;
}

.texts-bullet-list li:hover {
  background: rgba(183, 156, 92, 0.04);
}

.texts-bullet-list li::before {
  content: '\2014';
  position: absolute;
  left: 0.75rem;
  color: #b79c5c;
  opacity: 0.7;
}

/* ── Numbered list ───────────────────────────────────────────── */
.texts-numbered-list {
  padding-left: 1.75rem;
  margin: 0 0 0.75rem;
  max-width: 82ch;
}

.texts-numbered-list li {
  font-family: 'EB Garamond', serif;
  font-size: 1rem;
  color: #4f4742;
  line-height: 1.8;
  margin-bottom: 0.5rem;
  padding-left: 0.3rem;
}

.texts-numbered-list li::marker {
  color: #b79c5c;
  font-weight: 600;
}

/* ── Sub-categories (Follow-Up section) ─────────────────────── */
.texts-subcategory {
  margin-bottom: 2rem;
  padding: 1rem 1.25rem;
  background: rgba(255, 255, 255, 0.35);
  border: 1px solid rgba(199, 187, 170, 0.3);
  border-left: 3px solid rgba(183, 156, 92, 0.45);
  border-radius: 0 8px 8px 0;
}

.texts-subcategory-title {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #b79c5c;
  margin-bottom: 0.9rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid rgba(183, 156, 92, 0.15);
}

/* ── URL lists ───────────────────────────────────────────────── */
.texts-urls {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  margin-bottom: 0.75rem;
}

.texts-url {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  color: #b79c5c;
  text-decoration: underline;
  word-break: break-all;
  opacity: 0.8;
  transition: opacity 0.2s;
}

.texts-url:hover {
  opacity: 1;
}

/* ── Section body spacing ────────────────────────────────────── */
.texts-section-body {
  padding-left: 0.25rem;
}

/* ── "See all messages" button ───────────────────────────────── */
.texts-more-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  margin-top: 1.25rem;
  padding: 0.65rem 1.35rem;
  background: #f5f1eb;
  border: 1px solid #c7bbaa;
  border-radius: 8px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  font-weight: 600;
  color: #6a6156;
  text-decoration: none;
  transition: background 0.18s, color 0.18s, border-color 0.18s, transform 0.15s;
  letter-spacing: 0.02em;
}

.texts-more-btn:hover {
  background: #6a6156;
  color: #f3efe9;
  border-color: #6a6156;
  transform: translateY(-1px);
}

/* ── Responsive ──────────────────────────────────────────────── */
@media (max-width: 680px) {
  .texts-nav-grid {
    grid-template-columns: repeat(auto-fill, minmax(145px, 1fr));
  }

  .texts-nav-wrapper {
    padding: 1.25rem 1.1rem;
  }
}

@media (max-width: 520px) {
  .texts-nav-wrapper {
    padding: 1.1rem 1rem;
  }

  .texts-nav-grid {
    grid-template-columns: 1fr 1fr;
  }

  .texts-nav-btn {
    font-size: 0.68rem;
    padding: 0.55rem 0.75rem;
  }

  .texts-section-header {
    padding: 0.85rem 1rem;
  }

  .texts-message {
    padding: 0.9rem 1.1rem;
    font-size: 0.96rem;
  }

  .texts-bullet-list li {
    font-size: 0.96rem;
  }
}
</style>
