---
import BaseLayout from '../../layouts/BaseLayout.astro';

const books = [
  { slug: 'retire-before-mom-and-dad', title: 'Retire Before Mom and Dad' },
  { slug: 'tax-free-wealth',           title: 'Tax-Free Wealth' },
  { slug: 'managing-gods-money',       title: "Managing God's Money" },
];
---

<BaseLayout
  title="Manage Your Finances — Personal Takeaways"
  description="Personal takeaways from the Manage Your Finances shelf: Retire Before Mom and Dad, Tax-Free Wealth, and Managing God's Money."
>
  <a class="overlay-back" href="/">&#8592; Back to Bookshelf</a>
  <a class="overlay-close" href="/" aria-label="Close">&times;</a>

  <div class="takeaways-content">
    <span class="takeaways-tag">Manage Your Finances</span>
    <h1 class="takeaways-title">Manage Your Finances</h1>
    <p class="takeaways-author" style="margin-bottom: 0.5rem;">Personal Takeaways</p>

    <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:2rem;">
      {books.map((b) => (
        <a href={`/books/${b.slug}/`} class="overlay-takeaways-btn" style="font-size:0.78rem; padding:0.35rem 0.9rem;">
          {b.title}
        </a>
      ))}
    </div>

    <div class="overlay-coming-soon">
      Personal takeaways for this shelf haven't been added yet. Check back soon.
    </div>
  </div>
</BaseLayout>

<style>
  html { scroll-behavior: smooth; }
</style>
