---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Exercise Your Muscles — Weekly Workout Plan"
  description="Deep dive: a full 7-day weekly workout plan built on compound barbell push-pull supersets, VO2 max rowing intervals, Zone 2 cardio, and one full recovery day."
  canonicalPath="/exercise-your-muscles/takeaways-workout-plan/"
>
  <a class="overlay-back" href="/exercise-your-muscles/takeaways/">&#8592; Back to Takeaways</a>
  <a class="overlay-close" href="/" aria-label="Close">&times;</a>

  <div class="takeaways-content wp-wrap">

    <span class="takeaways-tag">Exercise Your Muscles</span>
    <h1 class="takeaways-title">Weekly Workout Plan</h1>

    <p class="wp-subtitle">The 7-Day Optimal Balance Schedule &middot; 30 minutes &middot; Strength + Cardio + Recovery</p>

    <div class="wp-grid">

      <!-- MONDAY -->
      <article class="wp-card" id="monday">
        <div class="wp-card-head">
          <span class="wp-day">Monday</span>
          <h3 class="wp-session">Upper Body Push/Pull</h3>
          <div class="wp-focus">Horizontal Focus</div>
        </div>
        <div class="wp-exercises">

          <div class="wp-exercise">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Bench Press</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">4 Sets</span>
                <span class="wp-role">Superset A1</span>
              </div>
            </div>
            <p class="wp-ex-desc">6–8 heavy reps. Barbell or dumbbell. 45 sec rest before A2.</p>
            <span class="wp-badge wp-badge--superset">Superset A</span>
          </div>

          <div class="wp-exercise">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Bent-Over Rows</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">4 Sets</span>
                <span class="wp-role">Superset A2</span>
              </div>
            </div>
            <p class="wp-ex-desc">6–8 heavy reps. Barbell or dumbbell. 45 sec rest, repeat A1.</p>
            <span class="wp-badge wp-badge--superset">Superset A</span>
          </div>

          <div class="wp-exercise wp-exercise--last">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Push-Ups</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">3 Sets</span>
              </div>
            </div>
            <p class="wp-ex-desc">To absolute failure.</p>
          </div>

        </div>
      </article>

      <!-- TUESDAY -->
      <article class="wp-card" id="tuesday">
        <div class="wp-card-head">
          <span class="wp-day">Tuesday</span>
          <h3 class="wp-session">Lower Body</h3>
          <div class="wp-focus">Testosterone Generator</div>
        </div>
        <div class="wp-exercises">

          <div class="wp-exercise">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Barbell Back Squats</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">4 Sets</span>
                <span class="wp-role">Main Lift</span>
              </div>
            </div>
            <p class="wp-ex-desc">6–8 reps. 90 sec rest. Do not superset — lift heavy safely.</p>
            <span class="wp-badge wp-badge--heavy">Heavy</span>
          </div>

          <div class="wp-exercise">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Bulgarian Split Squats</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">3 Sets</span>
                <span class="wp-role">Superset A1</span>
              </div>
            </div>
            <p class="wp-ex-desc">10 reps. Fixes imbalances, great for knee longevity.</p>
          </div>

          <div class="wp-exercise wp-exercise--last">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Hanging Leg Raises</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">3 Sets</span>
                <span class="wp-role">Superset A2</span>
              </div>
            </div>
            <p class="wp-ex-desc">10 reps. Or Ab Wheel Rollouts.</p>
          </div>

        </div>
      </article>

      <!-- WEDNESDAY -->
      <article class="wp-card" id="wednesday">
        <div class="wp-card-head">
          <span class="wp-day">Wednesday</span>
          <h3 class="wp-session">VO2 Max Intervals</h3>
          <div class="wp-focus">Rowing Machine</div>
        </div>
        <div class="wp-exercises">

          <div class="wp-exercise">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Rowing Warm-Up</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">4 min easy pace</span>
              </div>
            </div>
            <p class="wp-ex-desc">Easy, controlled strokes. Focus on form — drive with legs, lean back, pull to chest.</p>
            <span class="wp-badge wp-badge--cardio">Cardio</span>
          </div>

          <div class="wp-exercise wp-exercise--last">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Rowing Intervals</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">9 Rounds</span>
              </div>
            </div>
            <p class="wp-ex-desc">1:40 hard effort &rarr; 0:20 rest. Repeat &times; 9. Max sustainable output each interval.</p>
            <span class="wp-badge wp-badge--intervals">Intervals</span>
          </div>

        </div>
      </article>

      <!-- THURSDAY -->
      <article class="wp-card" id="thursday">
        <div class="wp-card-head">
          <span class="wp-day">Thursday</span>
          <h3 class="wp-session">Upper Body Push/Pull</h3>
          <div class="wp-focus">Vertical Focus</div>
        </div>
        <div class="wp-exercises">

          <div class="wp-exercise">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Overhead Press</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">4 Sets</span>
                <span class="wp-role">Superset A1</span>
              </div>
            </div>
            <p class="wp-ex-desc">6–8 reps. Standing barbell or dumbbells. Forces core to stabilize.</p>
            <span class="wp-badge wp-badge--superset">Superset A</span>
          </div>

          <div class="wp-exercise">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Weighted Pull-Ups / Lat Pulldowns</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">4 Sets</span>
                <span class="wp-role">Superset A2</span>
              </div>
            </div>
            <p class="wp-ex-desc">6–8 reps. 45 sec rest between exercises.</p>
            <span class="wp-badge wp-badge--superset">Superset A</span>
          </div>

          <div class="wp-exercise wp-exercise--last">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Dumbbell Hammer Curls</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">3 Sets</span>
              </div>
            </div>
            <p class="wp-ex-desc">10 reps. Builds bicep and elbow tendon health.</p>
          </div>

        </div>
      </article>

      <!-- FRIDAY -->
      <article class="wp-card" id="friday">
        <div class="wp-card-head">
          <span class="wp-day">Friday</span>
          <h3 class="wp-session">Lower Body Posterior Chain</h3>
          <div class="wp-focus">Bulletproofing</div>
        </div>
        <div class="wp-exercises">

          <div class="wp-exercise">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Romanian Deadlifts</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">4 Sets</span>
                <span class="wp-role">Main Lift</span>
              </div>
            </div>
            <p class="wp-ex-desc">6–8 reps. Or Trap-Bar Deadlifts. 90 sec rest. Core braced.</p>
            <span class="wp-badge wp-badge--heavy">Heavy</span>
          </div>

          <div class="wp-exercise">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Kettlebell Swings</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">3 Sets</span>
                <span class="wp-role">Superset A1</span>
              </div>
            </div>
            <p class="wp-ex-desc">15 reps. Explosive hip power.</p>
          </div>

          <div class="wp-exercise wp-exercise--last">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Face Pulls</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">3 Sets</span>
                <span class="wp-role">Superset A2</span>
              </div>
            </div>
            <p class="wp-ex-desc">15 reps. Cable or band. Key for shoulder health and reversing desk posture.</p>
          </div>

        </div>
      </article>

      <!-- SATURDAY -->
      <article class="wp-card" id="saturday">
        <div class="wp-card-head">
          <span class="wp-day">Saturday</span>
          <h3 class="wp-session">Zone 2 Steady State</h3>
          <div class="wp-focus">Heart Health &amp; Recovery</div>
        </div>
        <div class="wp-exercises">

          <div class="wp-exercise wp-exercise--last">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Outdoor or Indoor Bike Ride</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">30 min &mdash; alternative</span>
              </div>
            </div>
            <p class="wp-ex-desc">Easy to moderate effort outside, or a low-intensity Peloton ride. Stay in Zone 2 — resist the urge to push hard the day before rest day.</p>
            <span class="wp-badge wp-badge--zone2">Zone 2</span>
          </div>

        </div>
      </article>

      <!-- SUNDAY -->
      <article class="wp-card" id="sunday">
        <div class="wp-card-head">
          <span class="wp-day">Sunday</span>
          <h3 class="wp-session">Rest &amp; Recovery</h3>
          <div class="wp-focus">Active Recovery</div>
        </div>
        <div class="wp-exercises">

          <div class="wp-exercise wp-exercise--last">
            <div class="wp-ex-top">
              <span class="wp-ex-name">Guided Stretch or Yoga</span>
              <div class="wp-ex-meta">
                <span class="wp-sets">30 min</span>
              </div>
            </div>
            <p class="wp-ex-desc">Zero intense exercise. Follow a 30-min guided stretch or yoga routine on YouTube. Focus on hip flexors, hamstrings, and thoracic spine rotation. Muscle is torn in the gym — it's built while you rest.</p>
            <span class="wp-badge wp-badge--recovery">Recovery</span>
          </div>

        </div>
      </article>

    </div><!-- .wp-grid -->

  </div><!-- .wp-wrap -->
</BaseLayout>

<style>
/* ── Page wrapper ─────────────────────────────────────────────── */
.wp-wrap {
  max-width: 1080px;
}

/* ── Subtitle ─────────────────────────────────────────────────── */
.wp-subtitle {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.82rem;
  color: #7a7368;
  margin-top: -0.75rem;
  margin-bottom: 2rem;
  letter-spacing: 0.02em;
}

/* ── Card grid ────────────────────────────────────────────────── */
.wp-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
}

/* ── Individual day card ──────────────────────────────────────── */
.wp-card {
  background: rgba(255, 255, 255, 0.45);
  border: 1px solid rgba(199, 187, 170, 0.45);
  border-left: 3px solid #c2a86d;
  border-radius: 5px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.wp-card--full {
  grid-column: 1 / -1;
}

/* ── Card header ──────────────────────────────────────────────── */
.wp-card-head {
  padding: 0.9rem 1.1rem 0.7rem;
  background: rgba(183, 156, 92, 0.07);
  border-bottom: 1px solid rgba(183, 156, 92, 0.15);
}

.wp-day {
  display: block;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #b79c5c;
  margin-bottom: 0.2rem;
}

.wp-session {
  font-family: 'Playfair Display', serif;
  font-size: 1.05rem;
  font-weight: 600;
  color: #3d3830;
  line-height: 1.25;
  margin: 0 0 0.2rem 0;
}

.wp-focus {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.7rem;
  color: #7a7368;
  font-style: italic;
}

/* ── Exercises list ───────────────────────────────────────────── */
.wp-exercises {
  display: flex;
  flex-direction: column;
  flex: 1;
}

/* ── Single exercise row ──────────────────────────────────────── */
.wp-exercise {
  padding: 0.85rem 1.1rem 0.75rem;
  border-bottom: 1px solid rgba(199, 187, 170, 0.25);
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}

.wp-exercise--last {
  border-bottom: none;
  flex: 1;
}

.wp-ex-top {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.wp-ex-name {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.88rem;
  font-weight: 700;
  color: #3d3830;
  flex-shrink: 0;
}

.wp-ex-meta {
  display: flex;
  gap: 0.4rem;
  align-items: center;
  flex-shrink: 0;
}

.wp-sets {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.7rem;
  font-weight: 600;
  color: #1a56c4;
}

.wp-role {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.7rem;
  font-weight: 600;
  color: #1a56c4;
}

.wp-sets + .wp-role::before {
  content: '·';
  margin-right: 0.4rem;
  color: #b79c5c;
}

.wp-ex-desc {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.78rem;
  color: #5e554b;
  line-height: 1.55;
  margin: 0;
}

/* ── Badges ───────────────────────────────────────────────────── */
.wp-badge {
  display: inline-block;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.55rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 0.2rem 0.55rem;
  border-radius: 2px;
  align-self: flex-start;
  margin-top: 0.1rem;
}

.wp-badge--superset {
  background: rgba(26, 86, 196, 0.08);
  color: #1a56c4;
  border: 1px solid rgba(26, 86, 196, 0.2);
}

.wp-badge--heavy {
  background: rgba(26, 86, 196, 0.08);
  color: #1a56c4;
  border: 1px solid rgba(26, 86, 196, 0.2);
}

.wp-badge--cardio {
  background: rgba(22, 163, 74, 0.08);
  color: #16a34a;
  border: 1px solid rgba(22, 163, 74, 0.2);
}

.wp-badge--intervals {
  background: rgba(22, 163, 74, 0.08);
  color: #16a34a;
  border: 1px solid rgba(22, 163, 74, 0.2);
}

.wp-badge--zone2 {
  background: rgba(22, 163, 74, 0.08);
  color: #16a34a;
  border: 1px solid rgba(22, 163, 74, 0.2);
}

.wp-badge--recovery {
  background: rgba(183, 156, 92, 0.12);
  color: #8a6d1e;
  border: 1px solid rgba(183, 156, 92, 0.3);
}

/* ── Responsive: tablet ───────────────────────────────────────── */
@media (max-width: 860px) {
  .wp-grid {
    grid-template-columns: 1fr;
  }

  .wp-card--full {
    grid-column: auto;
  }
}

/* ── Responsive: mobile ───────────────────────────────────────── */
@media (max-width: 560px) {
  .wp-ex-top {
    flex-direction: column;
    gap: 0.2rem;
  }
}

html { scroll-behavior: smooth; }
</style>
