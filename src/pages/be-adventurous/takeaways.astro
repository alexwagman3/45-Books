---
import BaseLayout from '../../layouts/BaseLayout.astro';

const books = [
  { slug: 'microadventures',         title: 'Microadventures' },
  { slug: 'wild-at-heart',           title: 'Wild at Heart' },
  { slug: 'the-happiness-of-pursuit', title: 'The Happiness of Pursuit' },
];
---

<BaseLayout
  title="Be Adventurous — Personal Takeaways"
  description="Personal takeaways from the Be Adventurous shelf: Microadventures, Wild at Heart, and The Happiness of Pursuit."
>
  <a class="overlay-back" href="/">&#8592; Back to Bookshelf</a>
  <a class="overlay-close" href="/" aria-label="Close">&times;</a>

  <div class="takeaways-content">
    <span class="takeaways-tag">Be Adventurous</span>
    <h1 class="takeaways-title">Be Adventurous</h1>
    <p class="takeaways-author" style="margin-bottom: 0.5rem;">Personal Takeaways</p>

    <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:2rem;">
      {books.map((b) => (
        <a href={`/books/${b.slug}/`} class="overlay-takeaways-btn" style="font-size:0.78rem; padding:0.35rem 0.9rem;">
          {b.title}
        </a>
      ))}
    </div>

    <div class="overlay-coming-soon">
      Personal takeaways for this shelf haven't been added yet. Check back soon.
    </div>
  </div>
</BaseLayout>

<style>
  html { scroll-behavior: smooth; }
</style>
