import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Grow in Wisdom — Weekly Character Plan"
  description="Deep dive: a full 8-trait weekly character formation plan built around Loving, Humble, Self-Controlled, Hopeful, Wise, Joyful, Peaceful, and Courageous — each with a four-step reflection framework."
>
  <a class="overlay-back" href="/grow-in-wisdom/takeaways/">&#8592; Back to Takeaways</a>
  <a class="overlay-close" href="/" aria-label="Close">&times;</a>

  <div class="takeaways-content">
    <span class="takeaways-tag">Grow in Wisdom</span>
    <h1 class="takeaways-title">Weekly Character Plan</h1>

    <div class="dd-topic-list">
      <a class="dd-topic-link" href="#giw-plan-table">8-Trait Schedule</a>
    </div>

    <div class="tk-section" id="giw-plan-table">
      <div class="tk-section-title">8-Trait Weekly Schedule</div>
      <div class="fyb-table-wrap">
        <table class="fyb-table" style="min-width:720px">
          <thead>
            <tr>
              <th style="width:9%">Day</th>
              <th style="width:15%">Trait</th>
              <th>Reflection Questions</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="fyb-day">Day 1</td>
              <td><strong>Loving</strong></td>
              <td>
                <ul>
                  <li><strong>Recall:</strong> Think of one specific person you struggled to love this week. What happened?</li>
                  <li><strong>Examine:</strong> What was underneath your response — fear, hurt, pride, or indifference?</li>
                  <li><strong>Apply:</strong> What is one concrete act of love you will offer that person this week?</li>
                  <li><strong>Pray:</strong> Ask God to expand your capacity to love as He loves — without condition, without limit.</li>
                </ul>
              </td>
            </tr>
            <tr>
              <td class="fyb-day">Day 2</td>
              <td><strong>Humble</strong></td>
              <td>
                <ul>
                  <li><strong>Recall:</strong> When did you seek credit, resist correction, or elevate yourself above others this week?</li>
                  <li><strong>Examine:</strong> What insecurity or need for status was underneath it?</li>
                  <li><strong>Apply:</strong> Where can you defer, listen, or give credit to someone else this week?</li>
                  <li><strong>Pray:</strong> Ask God to replace self-promotion with servant-heartedness in your daily interactions.</li>
                </ul>
              </td>
            </tr>
            <tr>
              <td class="fyb-day">Day 3</td>
              <td><strong>Self-Controlled</strong></td>
              <td>
                <ul>
                  <li><strong>Recall:</strong> Where did appetite, anger, or impulse win over your intentions this week?</li>
                  <li><strong>Examine:</strong> What triggered it — stress, loneliness, boredom, or an old habit?</li>
                  <li><strong>Apply:</strong> What one boundary or practice will you put in place before that trigger hits again?</li>
                  <li><strong>Pray:</strong> Ask God to produce the fruit of self-control in your desires and reactions.</li>
                </ul>
              </td>
            </tr>
            <tr>
              <td class="fyb-day">Day 4</td>
              <td><strong>Hopeful</strong></td>
              <td>
                <ul>
                  <li><strong>Recall:</strong> Where did anxiety, dread, or cynicism dominate your thinking this week?</li>
                  <li><strong>Examine:</strong> What were you trusting in instead of God's promises?</li>
                  <li><strong>Apply:</strong> What specific promise of God will you return to when that fear comes back?</li>
                  <li><strong>Pray:</strong> Ask God to anchor your hope in what is true, certain, and coming — not in what you can see.</li>
                </ul>
              </td>
            </tr>
            <tr>
              <td class="fyb-day">Day 5</td>
              <td><strong>Wise</strong></td>
              <td>
                <ul>
                  <li><strong>Recall:</strong> Where did you make a decision this week without enough reflection, counsel, or prayer?</li>
                  <li><strong>Examine:</strong> What was the rush? What did you prioritize over seeking wisdom?</li>
                  <li><strong>Apply:</strong> What decision currently in front of you needs more prayer and counsel before you act?</li>
                  <li><strong>Pray:</strong> Ask God for wisdom that comes from above — pure, peaceable, and impartial.</li>
                </ul>
              </td>
            </tr>
            <tr>
              <td class="fyb-day">Day 6</td>
              <td><strong>Joyful</strong></td>
              <td>
                <ul>
                  <li><strong>Recall:</strong> When did you notice genuine joy this week — and when did it disappear?</li>
                  <li><strong>Examine:</strong> What are you tying your joy to that God hasn't promised to sustain?</li>
                  <li><strong>Apply:</strong> What practice will you add this week to cultivate joy that is independent of circumstances?</li>
                  <li><strong>Pray:</strong> Ask God to produce a joy the world didn't give and cannot take away.</li>
                </ul>
              </td>
            </tr>
            <tr>
              <td class="fyb-day">Day 7</td>
              <td><strong>Peaceful</strong></td>
              <td>
                <ul>
                  <li><strong>Recall:</strong> Where did anxiety, conflict, or restlessness steal your peace this week?</li>
                  <li><strong>Examine:</strong> What were you trying to control that belongs in God's hands?</li>
                  <li><strong>Apply:</strong> What will you deliberately release this week — and what will you replace the worry with?</li>
                  <li><strong>Pray:</strong> Ask God for the peace that surpasses understanding to guard your heart and mind.</li>
                </ul>
              </td>
            </tr>
            <tr>
              <td class="fyb-day">Day 8</td>
              <td><strong>Courageous</strong></td>
              <td>
                <ul>
                  <li><strong>Recall:</strong> Where did fear cause you to stay silent, shrink back, or avoid the right thing this week?</li>
                  <li><strong>Examine:</strong> What were you protecting — reputation, comfort, or someone's approval?</li>
                  <li><strong>Apply:</strong> What one courageous act — a conversation, a decision, or a stand — will you take this week?</li>
                  <li><strong>Pray:</strong> Ask God to fill you with courage that comes from knowing He goes before you.</li>
                </ul>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  html { scroll-behavior: smooth; }
</style>
